<div class="w-full max-w-4xl mx-auto">
  <!-- 成功提示 -->
  <div class="mb-8 text-center">
    <div class="inline-flex items-center justify-center w-20 h-20 bg-green-100 rounded-full mb-4">
      <svg class="w-12 h-12 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
      </svg>
    </div>
    <h1 class="text-4xl font-bold text-gray-900 mb-2">订单提交成功！</h1>
    
    <!-- 订单编号 - 突出显示 -->
    <div class="inline-block bg-blue-50 border border-blue-200 rounded-lg px-6 py-3 mb-4">
      <p class="text-sm text-blue-600 mb-1">您的订单编号</p>
      <p class="text-3xl font-bold text-blue-700">#<%= @order.id.to_s.rjust(6, '0') %></p>
    </div>
    
    <p class="text-gray-600 mb-3">感谢您的购买，我们会尽快为您安排发货</p>
    
    <!-- Email 通知说明 -->
    <div class="max-w-md mx-auto bg-green-50 border border-green-200 rounded-lg p-4">
      <div class="flex items-start">
        <svg class="w-5 h-5 text-green-600 mt-0.5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
        </svg>
        <div class="text-left">
          <p class="text-sm font-semibold text-green-900 mb-1">📧 我们会通过邮件联系您</p>
          <p class="text-xs text-green-700">订单确认、支付链接和发货通知将发送至 <span class="font-semibold"><%= @order.email %></span></p>
        </div>
      </div>
    </div>
  </div>

  <!-- 订单信息卡片 -->
  <div class="bg-white rounded-lg shadow-lg overflow-hidden mb-6">
    <!-- 订单头部 -->
    <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-8 py-6">
      <div class="flex justify-between items-center text-white">
        <div>
          <p class="text-sm opacity-90">订单号</p>
          <p class="text-2xl font-bold">#<%= @order.id.to_s.rjust(6, '0') %></p>
        </div>
        <div class="text-right">
          <p class="text-sm opacity-90">订单状态</p>
          <span class="inline-block px-4 py-2 bg-white bg-opacity-20 rounded-full text-sm font-semibold mt-1">
            <%= @order.status == 'pending' ? '待支付' : @order.status %>
          </span>
        </div>
      </div>
    </div>

    <!-- 订单详情 -->
    <div class="p-8">
      <!-- 联系人信息 -->
      <div class="mb-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center">
          <svg class="w-6 h-6 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
          联系人信息
        </h2>
        <div class="bg-gray-50 rounded-lg p-4 space-y-2">
          <div class="flex">
            <span class="text-gray-600 w-20">姓名:</span>
            <span class="text-gray-900 font-medium"><%= @order.name %></span>
          </div>
          <div class="flex">
            <span class="text-gray-600 w-20">邮箱:</span>
            <span class="text-gray-900"><%= @order.email %></span>
          </div>
          <div class="flex">
            <span class="text-gray-600 w-20">手机:</span>
            <span class="text-gray-900"><%= @order.phone %></span>
          </div>
        </div>
      </div>

      <!-- 配送地址 -->
      <div class="mb-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center">
          <svg class="w-6 h-6 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          配送地址
        </h2>
        <div class="bg-gray-50 rounded-lg p-4">
          <p class="text-gray-900"><%= @order.address %></p>
        </div>
      </div>

      <!-- 商品列表 -->
      <div class="mb-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center">
          <svg class="w-6 h-6 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
          </svg>
          订单商品
        </h2>
        <div class="border border-gray-200 rounded-lg overflow-hidden">
          <table class="w-full">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">商品</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">单价</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">数量</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">小计</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @order.order_items.includes(:product).each do |order_item| %>
                <tr>
                  <td class="px-6 py-4">
                    <div class="flex items-center">
                      <% if order_item.product.image.attached? %>
                        <%= image_tag order_item.product.image, class: "h-16 w-16 object-cover rounded" %>
                      <% else %>
                        <div class="h-16 w-16 bg-gray-200 rounded flex items-center justify-center">
                          <span class="text-gray-400 text-xs">无图</span>
                        </div>
                      <% end %>
                      <div class="ml-4">
                        <p class="text-sm font-medium text-gray-900"><%= order_item.product.name %></p>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4 text-center text-sm text-gray-900">
                    ¥<%= number_to_currency(order_item.price, unit: "", precision: 2) %>
                  </td>
                  <td class="px-6 py-4 text-center text-sm text-gray-900">
                    <%= order_item.quantity %>
                  </td>
                  <td class="px-6 py-4 text-right text-sm font-semibold text-gray-900">
                    ¥<%= number_to_currency(order_item.subtotal, unit: "", precision: 2) %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- 订单总额 -->
      <div class="flex justify-end">
        <div class="w-80">
          <div class="space-y-2 mb-4">
            <div class="flex justify-between text-gray-600">
              <span>商品总计</span>
              <span>¥<%= number_to_currency(@order.total_price, unit: "", precision: 2) %></span>
            </div>
            <div class="flex justify-between text-gray-600">
              <span>运费</span>
              <span>免运费</span>
            </div>
          </div>
          <div class="border-t-2 pt-4">
            <div class="flex justify-between items-center">
              <span class="text-xl font-semibold text-gray-900">订单总计</span>
              <span class="text-3xl font-bold text-blue-600">
                ¥<%= number_to_currency(@order.total_price, unit: "", precision: 2) %>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 操作按钮 -->
  <div class="flex justify-center space-x-4">
    <%= link_to products_path, class: "bg-gray-200 hover:bg-gray-300 text-gray-800 font-bold py-3 px-8 rounded-lg transition-colors" do %>
      继续购物
    <% end %>
    
    <% if @order.pending? %>
      <%= link_to "#", class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-lg transition-colors" do %>
        立即支付
      <% end %>
    <% end %>
  </div>

  <!-- 温馨提示 -->
  <div class="mt-8 bg-blue-50 border border-blue-100 rounded-lg p-6">
    <div class="flex items-start mb-4">
      <svg class="w-6 h-6 text-blue-600 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <div>
        <h3 class="font-semibold text-blue-900 mb-2">接下来会发生什么？</h3>
        <ul class="text-sm text-blue-800 space-y-2">
          <li class="flex items-start">
            <span class="text-blue-600 mr-2">1.</span>
            <span>您将收到订单确认邮件（<span class="font-semibold"><%= @order.email %></span>）</span>
          </li>
          <li class="flex items-start">
            <span class="text-blue-600 mr-2">2.</span>
            <span>我们会通过邮件发送支付链接</span>
          </li>
          <li class="flex items-start">
            <span class="text-blue-600 mr-2">3.</span>
            <span>支付成功后，我们会立即安排发货</span>
          </li>
          <li class="flex items-start">
            <span class="text-blue-600 mr-2">4.</span>
            <span>发货后会通过短信/邮件通知物流信息</span>
          </li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-blue-200 pt-4 mt-4">
      <p class="text-sm text-blue-800 flex items-center">
        <svg class="w-5 h-5 text-blue-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span><strong>请保存订单号 #<%= @order.id.to_s.rjust(6, '0') %></strong>，以便查询订单状态或联系客服时使用</span>
      </p>
    </div>
  </div>
</div>
