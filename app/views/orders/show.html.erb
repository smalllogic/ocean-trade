<div class="w-full max-w-4xl mx-auto">
  <!-- 成功提示 -->
  <div class="mb-8 text-center">
    <div class="inline-flex items-center justify-center w-20 h-20 bg-green-100 rounded-full mb-4">
      <svg class="w-12 h-12 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
      </svg>
    </div>
    <h1 class="text-4xl font-bold text-gray-900 mb-2">
      <%= @order.paid? ? "Payment Successful!" : "Order Placed Successfully!" %>
    </h1>
    
    <!-- Order Number - Highlight -->
    <div class="inline-block bg-blue-50 border border-blue-200 rounded-lg px-6 py-3 mb-4">
      <p class="text-sm text-blue-600 mb-1">Your Order Number</p>
      <p class="text-3xl font-bold text-blue-700">#<%= @order.id.to_s.rjust(6, '0') %></p>
    </div>
    
    <p class="text-gray-600 mb-3">
      <%= @order.paid? ? "Thank you for your payment! We are processing your order." : "Thank you for your purchase! We will arrange shipping as soon as possible." %>
    </p>
    
    <!-- Email Notification -->
    <div class="max-w-md mx-auto bg-green-50 border border-green-200 rounded-lg p-4">
      <div class="flex items-start">
        <svg class="w-5 h-5 text-green-600 mt-0.5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
        </svg>
        <div class="text-left">
          <p class="text-sm font-semibold text-green-900 mb-1">📧 We will contact you via email</p>
          <p class="text-xs text-green-700">
            <%= @order.paid? ? "A payment confirmation and shipping updates" : "Order confirmation, payment links, and shipping notifications" %>
            will be sent to <span class="font-semibold"><%= @order.email %></span>
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Order Info Card -->
  <div class="bg-white rounded-lg shadow-lg overflow-hidden mb-6">
    <!-- Order Header -->
    <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-8 py-6">
      <div class="flex justify-between items-center text-white">
        <div>
          <p class="text-sm opacity-90">Order ID</p>
          <p class="text-2xl font-bold">#<%= @order.id.to_s.rjust(6, '0') %></p>
        </div>
        <div class="text-right">
          <p class="text-sm opacity-90">Order Status</p>
          <span class="inline-block px-4 py-2 bg-white bg-opacity-20 rounded-full text-sm font-semibold mt-1">
            <%= @order.status == 'pending' ? 'Pending Payment' : @order.status.capitalize %>
          </span>
        </div>
      </div>
    </div>

    <!-- Order Details -->
    <div class="p-8">
      <!-- Contact Information -->
      <div class="mb-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center">
          <svg class="w-6 h-6 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
          Contact Information
        </h2>
        <div class="bg-gray-50 rounded-lg p-4 space-y-2">
          <div class="flex">
            <span class="text-gray-600 w-20">Name:</span>
            <span class="text-gray-900 font-medium"><%= @order.name %></span>
          </div>
          <div class="flex">
            <span class="text-gray-600 w-20">Email:</span>
            <span class="text-gray-900"><%= @order.email %></span>
          </div>
          <div class="flex">
            <span class="text-gray-600 w-20">Phone:</span>
            <span class="text-gray-900"><%= @order.phone %></span>
          </div>
        </div>
      </div>

      <!-- Shipping Address -->
      <div class="mb-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center">
          <svg class="w-6 h-6 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          Shipping Address
        </h2>
        <div class="bg-gray-50 rounded-lg p-4">
          <p class="text-gray-900"><%= @order.address %></p>
        </div>
      </div>

      <!-- Item List -->
      <div class="mb-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center">
          <svg class="w-6 h-6 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
          </svg>
          Order Items
        </h2>
        <div class="border border-gray-200 rounded-lg overflow-hidden">
          <table class="w-full">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Product</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Unit Price</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Quantity</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Subtotal</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @order.order_items.includes(product_variant: :product).each do |order_item| %>
                <% variant = order_item.product_variant %>
                <% product = variant.product %>
                <tr>
                  <td class="px-6 py-4">
                    <div class="flex items-center">
                      <% if product.images.attached? %>
                        <%= image_tag product.images.first, class: "h-16 w-16 object-cover rounded" %>
                      <% else %>
                        <div class="h-16 w-16 bg-gray-200 rounded flex items-center justify-center">
                          <span class="text-gray-400 text-xs">No Image</span>
                        </div>
                      <% end %>
                      <div class="ml-4">
                        <p class="text-sm font-medium text-gray-900"><%= product.name %></p>
                        <p class="text-xs text-gray-500 font-medium">Option: <%= variant.title %></p>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4 text-center text-sm text-gray-900">
                    ¥<%= number_to_currency(order_item.price, unit: "", precision: 2) %>
                  </td>
                  <td class="px-6 py-4 text-center text-sm text-gray-900">
                    <%= order_item.quantity %>
                  </td>
                  <td class="px-6 py-4 text-right text-sm font-semibold text-gray-900">
                    ¥<%= number_to_currency(order_item.subtotal, unit: "", precision: 2) %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Order Totals -->
      <div class="flex justify-end">
        <div class="w-80">
          <div class="space-y-2 mb-4">
            <div class="flex justify-between text-gray-600">
              <span>Items Total</span>
              <span>¥<%= number_to_currency(@order.total_price, unit: "", precision: 2) %></span>
            </div>
            <div class="flex justify-between text-gray-600">
              <span>Shipping</span>
              <span>Free Shipping</span>
            </div>
          </div>
          <div class="border-t-2 pt-4">
            <div class="flex justify-between items-center">
              <span class="text-xl font-semibold text-gray-900">Order Total</span>
              <span class="text-3xl font-bold text-blue-600">
                ¥<%= number_to_currency(@order.total_price, unit: "", precision: 2) %>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Action Buttons -->
  <div class="flex flex-col items-center justify-center space-y-4">
    <% if @order.pending? %>
      <div id="paypal-button-container" class="w-full max-w-md"></div>
    <% end %>

    <div class="flex justify-center space-x-4">
      <%= link_to products_path, class: "bg-gray-200 hover:bg-gray-300 text-gray-800 font-bold py-3 px-8 rounded-lg transition-colors" do %>
        Continue Shopping
      <% end %>
    </div>
  </div>

  <% if @order.pending? %>
    <% client_id = Rails.application.credentials.dig(:paypal, :client_id) || "AfXsj5DQPtRsifmJ6-zEDj7HSRAcM7TCGFUV7-9m_Se06WKHDpqWR3fQFhj8ZUILI-i6l83HL8mTwny-" %>
    <script src="https://www.paypal.com/sdk/js?client-id=<%= client_id %>&currency=USD" data-turbo-eval="false"></script>
    <script>
      function renderPayPalButton() {
        const container = document.querySelector('#paypal-button-container');
        if (!container || container.children.length > 0) return;

        paypal.Buttons({
          createOrder: function(data, actions) {
            return actions.order.create({
              purchase_units: [{
                amount: {
                  value: '<%= @order.total_price %>'
                },
                custom_id: '<%= @order.id %>'
              }]
            });
          },
          onApprove: function(data, actions) {
            return actions.order.capture().then(function(details) {
              // 支付成功，通知服务器
              return fetch('/orders/<%= @order.id %>/capture_paypal_order', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                  'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
                },
                body: JSON.stringify({
                  paypal_order_id: data.orderID
                })
              }).then(function(response) {
                if (response.ok) {
                  window.location.reload();
                } else {
                  alert('Payment verification failed. Please contact support.');
                }
              });
            });
          },
          onError: function(err) {
            console.error('PayPal Error:', err);
            // alert('An error occurred during the payment process.');
          }
        }).render('#paypal-button-container');
      }

      // Initial load
      document.addEventListener('turbo:load', renderPayPalButton);
      // Fallback if turbo:load already fired
      if (typeof paypal !== 'undefined') {
        renderPayPalButton();
      }
    </script>
  <% end %>

  <!-- Helpful Tips -->
  <div class="mt-8 bg-blue-50 border border-blue-100 rounded-lg p-6">
    <div class="flex items-start mb-4">
      <svg class="w-6 h-6 text-blue-600 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <div>
        <h3 class="font-semibold text-blue-900 mb-2">What happens next?</h3>
        <ul class="text-sm text-blue-800 space-y-2">
          <li class="flex items-start">
            <span class="text-blue-600 mr-2">1.</span>
            <span>You will receive an order confirmation email (<span class="font-semibold"><%= @order.email %></span>)</span>
          </li>
          <% if @order.pending? %>
            <li class="flex items-start">
              <span class="text-blue-600 mr-2">2.</span>
              <span>Please complete the payment using the PayPal button above</span>
            </li>
          <% end %>
          <li class="flex items-start">
            <span class="text-blue-600 mr-2"><%= @order.pending? ? "3." : "2." %></span>
            <span>Once payment is successful, we will arrange shipping immediately</span>
          </li>
          <li class="flex items-start">
            <span class="text-blue-600 mr-2"><%= @order.pending? ? "4." : "3." %></span>
            <span>Tracking information will be sent via SMS/Email after dispatch</span>
          </li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-blue-200 pt-4 mt-4">
      <p class="text-sm text-blue-800 flex items-center">
        <svg class="w-5 h-5 text-blue-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span><strong>Please save your Order Number #<%= @order.id.to_s.rjust(6, '0') %></strong> for tracking status or contacting support</span>
      </p>
    </div>
  </div>
</div>
