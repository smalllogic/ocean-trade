<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold">分类管理</h1>
  <%= link_to '新建分类', new_admin_category_path, class: "bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600" %>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">名称</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">层级</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">操作</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% def render_categories(categories, level = 0) %>
        <% categories.each do |category| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap">
              <span style="margin-left: <%= level * 20 %>px;">
                <%= "┕ " if level > 0 %><%= category.name %>
              </span>
              <% if category.products.any? %>
                <span class="ml-2 px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                  <%= category.products.count %> 个产品
                </span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= level + 1 %> 级
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <%= link_to '编辑', edit_admin_category_path(category), class: "text-blue-600 hover:text-blue-900 mr-3" %>
              <%= link_to '删除', admin_category_path(category), data: { turbo_method: :delete, turbo_confirm: '确定删除吗？' }, class: "text-red-600 hover:text-red-900" %>
            </td>
          </tr>
          <% render_categories(category.children, level + 1) if category.children.any? %>
        <% end %>
      <% end %>
      
      <% render_categories(@categories) %>
    </tbody>
  </table>
</div>
