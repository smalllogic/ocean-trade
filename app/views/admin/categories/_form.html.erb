<div class="max-w-2xl mx-auto bg-white p-8 rounded-lg shadow">
  <h1 class="text-2xl font-bold mb-6 text-center"><%= @category.new_record? ? 'New Category' : 'Edit Category' %></h1>

  <%= form_with(model: [:admin, @category], local: true) do |f| %>
    <% if @category.errors.any? %>
      <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-6">
        <ul class="list-disc ml-5 text-red-700">
          <% @category.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-4">
      <%= f.label :name, "Category Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, class: "w-full border rounded-md px-3 py-2" %>
    </div>

    <div class="mb-6">
      <%= f.label :parent_id, "Parent Category", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.collection_select :parent_id, Category.where.not(id: @category.id), :id, :name, { include_blank: "None (as top-level category)" }, { class: "w-full border rounded-md px-3 py-2" } %>
      <p class="mt-1 text-xs text-gray-500">Note: Business rule: If a category already has products, it cannot be set as a parent category.</p>
    </div>

    <div class="flex justify-end gap-3">
      <%= link_to 'Back to List', admin_categories_path, class: "px-4 py-2 text-gray-600 bg-gray-100 rounded hover:bg-gray-200 transition-colors" %>
      <%= f.submit @category.new_record? ? "Create" : "Update", class: "px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 cursor-pointer transition-colors" %>
    </div>
  <% end %>
</div>
