<div class="max-w-2xl mx-auto bg-white p-8 rounded-lg shadow">
  <h1 class="text-2xl font-bold mb-6 text-center"><%= @category.new_record? ? '新建分类' : '编辑分类' %></h1>

  <%= form_with(model: [:admin, @category], local: true) do |f| %>
    <% if @category.errors.any? %>
      <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-6">
        <ul class="list-disc ml-5 text-red-700">
          <% @category.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-4">
      <%= f.label :name, "分类名称", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, class: "w-full border rounded-md px-3 py-2" %>
    </div>

    <div class="mb-6">
      <%= f.label :parent_id, "上级分类", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.collection_select :parent_id, Category.where.not(id: @category.id), :id, :name, { include_blank: "无 (作为一级分类)" }, { class: "w-full border rounded-md px-3 py-2" } %>
      <p class="mt-1 text-xs text-gray-500">注意：业务规则限制：若上级分类已有产品，则无法将其作为父分类添加子节点。</p>
    </div>

    <div class="flex justify-end gap-3">
      <%= link_to '返回列表', admin_categories_path, class: "px-4 py-2 text-gray-600 bg-gray-100 rounded hover:bg-gray-200 transition-colors" %>
      <%= f.submit @category.new_record? ? "创建" : "更新", class: "px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 cursor-pointer transition-colors" %>
    </div>
  <% end %>
</div>
