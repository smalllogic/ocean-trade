<div class="w-full max-w-4xl mx-auto">
  <div class="mb-6 flex justify-between items-center">
    <%= link_to "← Back to Product List", admin_products_path, class: "text-blue-600 hover:text-blue-800" %>
    <div class="space-x-2">
      <%= link_to "Edit", edit_admin_product_path(@product), class: "bg-green-500 hover:bg-green-600 text-white font-bold py-2 px-4 rounded-lg transition" %>
      <%= link_to "Delete", admin_product_path(@product), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this product?" }, class: "bg-red-500 hover:bg-red-600 text-white font-bold py-2 px-4 rounded-lg transition" %>
    </div>
  </div>

  <div class="bg-white shadow-lg rounded-lg overflow-hidden">
    <!-- 产品图片 -->
    <% if @product.images.attached? %>
      <div class="w-full bg-gray-100 p-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <% @product.images.each do |image| %>
            <%= image_tag image, class: "w-full h-64 object-contain bg-white rounded-lg shadow" %>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="w-full h-96 bg-gray-200 flex items-center justify-center">
        <span class="text-gray-400 text-xl">No Product Image</span>
      </div>
    <% end %>

    <!-- 产品信息 -->
    <div class="p-8">
      <!-- Status Label -->
      <div class="mb-4">
        <% if @product.hidden? %>
          <span class="px-3 py-1 inline-flex text-sm leading-5 font-semibold rounded-full bg-red-100 text-red-800">
            Hidden
          </span>
        <% else %>
          <span class="px-3 py-1 inline-flex text-sm leading-5 font-semibold rounded-full bg-green-100 text-green-800">
            Visible
          </span>
        <% end %>
      </div>

      <!-- 产品名称 -->
      <h1 class="text-4xl font-bold text-gray-900 mb-4"><%= @product.name %></h1>

      <!-- 价格 -->
      <div class="mb-6">
        <% if @product.variants.any? %>
          <span class="text-3xl font-bold text-blue-600">
            ¥<%= number_to_currency(@product.min_price, unit: "", precision: 2) %>
            <% if @product.min_price != @product.max_price %>
              - ¥<%= number_to_currency(@product.max_price, unit: "", precision: 2) %>
            <% end %>
          </span>
        <% else %>
          <span class="text-3xl font-bold text-blue-600">¥<%= number_to_currency(@product.price, unit: "", precision: 2) %></span>
        <% end %>
      </div>

      <!-- Summary -->
      <% if @product.summary.present? %>
        <div class="mb-6 p-4 bg-blue-50 border-l-4 border-blue-500 rounded text-blue-900">
          <p class="font-medium"><%= @product.summary %></p>
        </div>
      <% end %>

      <!-- Variants Table -->
      <% if @product.variants.any? %>
        <div class="border-t pt-6 mb-8">
          <h2 class="text-xl font-semibold text-gray-900 mb-4">Product Variants</h2>
          <div class="bg-gray-50 rounded-lg overflow-hidden border border-gray-200">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-100">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Title</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Price</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Stock</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">SKU</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200">
                <% @product.variants.ordered.each do |variant| %>
                  <tr>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= variant.title %></td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">¥<%= number_to_currency(variant.price, unit: "", precision: 2) %></td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= variant.stock %></td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= variant.sku %></td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full <%= variant.is_active ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                        <%= variant.is_active ? 'Active' : 'Inactive' %>
                      </span>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>

      <!-- Description -->
      <div class="border-t pt-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-3">Product Description</h2>
        <% if @product.description.present? %>
          <p class="text-gray-700 leading-relaxed whitespace-pre-wrap"><%= @product.description %></p>
        <% else %>
          <p class="text-gray-400 italic">No description</p>
        <% end %>
      </div>

      <!-- Metadata -->
      <div class="border-t mt-8 pt-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-3">Product Information</h2>
        <dl class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <dt class="text-sm font-medium text-gray-500">Created</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @product.created_at.strftime("%B %d, %Y %H:%M") %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Updated</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @product.updated_at.strftime("%B %d, %Y %H:%M") %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Product ID</dt>
            <dd class="mt-1 text-sm text-gray-900">#<%= @product.id %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Status</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @product.hidden? ? "Hidden" : "Visible" %></dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</div>
