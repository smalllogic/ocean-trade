<%= simple_form_for [:admin, product] do |f| %>
  <%= f.error_notification %>
  <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

  <div class="space-y-6">
    <!-- 产品名称 -->
    <div>
      <%= f.label :name, "产品名称", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.input :name, label: false, placeholder: "请输入产品名称", input_html: { class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" } %>
    </div>

    <!-- 价格 -->
    <div>
      <%= f.label :price, "价格", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.input :price, label: false, placeholder: "0.00", input_html: { class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" } %>
      <p class="mt-1 text-sm text-gray-500">请输入产品价格（元）</p>
    </div>

    <!-- 描述 -->
    <div>
      <%= f.label :description, "产品描述", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.input :description, label: false, as: :text, placeholder: "请输入产品描述", input_html: { rows: 6, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" } %>
    </div>

    <!-- 产品图片 -->
    <div>
      <%= f.label :image, "产品图片", class: "block text-sm font-medium text-gray-700 mb-2" %>
      
      <% if product.image.attached? %>
        <div class="mb-4">
          <%= image_tag product.image, class: "rounded-lg shadow-md max-w-xs" %>
        </div>
      <% end %>
      
      <%= f.input :image, label: false, as: :file, input_html: { accept: "image/*", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" } %>
      <p class="mt-1 text-sm text-gray-500">支持 JPG、PNG、GIF 格式</p>
    </div>

    <!-- 是否隐藏 -->
    <div>
      <div class="flex items-center">
        <%= f.input :is_hidden, label: false, as: :boolean, input_html: { class: "h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" } %>
        <%= f.label :is_hidden, "隐藏此产品（用户将看不到）", class: "ml-2 block text-sm text-gray-700" %>
      </div>
    </div>

    <!-- 按钮 -->
    <div class="flex items-center justify-between pt-4 border-t">
      <%= link_to "取消", admin_products_path, class: "text-gray-600 hover:text-gray-800 font-medium" %>
      <%= f.button :submit, product.new_record? ? "创建产品" : "更新产品", class: "bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-8 rounded-lg transition" %>
    </div>
  </div>
<% end %>
