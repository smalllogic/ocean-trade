<div class="w-full">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900">产品管理</h1>
    <%= link_to "新增产品", new_admin_product_path, class: "bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-6 rounded-lg transition" %>
  </div>

  <% if @products.any? %>
    <div class="bg-white shadow-lg rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">图片</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">名称</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">价格</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">状态</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">创建时间</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">操作</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @products.each do |product| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <% if product.image.attached? %>
                  <%= image_tag product.image, class: "h-16 w-16 object-cover rounded" %>
                <% else %>
                  <div class="h-16 w-16 bg-gray-200 rounded flex items-center justify-center">
                    <span class="text-gray-400 text-xs">无图片</span>
                  </div>
                <% end %>
              </td>
              <td class="px-6 py-4">
                <div class="text-sm font-medium text-gray-900"><%= product.name %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-900">¥<%= number_to_currency(product.price, unit: "", precision: 2) %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% if product.hidden? %>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">
                    已隐藏
                  </span>
                <% else %>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                    显示中
                  </span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= product.created_at.strftime("%Y-%m-%d") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <div class="flex justify-end space-x-2">
                  <%= link_to "查看", admin_product_path(product), class: "text-blue-600 hover:text-blue-900" %>
                  <%= link_to "编辑", edit_admin_product_path(product), class: "text-green-600 hover:text-green-900" %>
                  <%= link_to "删除", admin_product_path(product), data: { turbo_method: :delete, turbo_confirm: "确定要删除这个产品吗？" }, class: "text-red-600 hover:text-red-900" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white shadow-lg rounded-lg p-12 text-center">
      <p class="text-gray-500 text-lg mb-4">还没有任何产品</p>
      <%= link_to "创建第一个产品", new_admin_product_path, class: "bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-6 rounded-lg transition inline-block" %>
    </div>
  <% end %>
</div>
