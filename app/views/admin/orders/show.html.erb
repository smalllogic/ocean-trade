<div class="container mx-auto px-4 py-8">
  <!-- 头部 -->
  <div class="mb-8">
    <%= link_to admin_orders_path, class: "text-blue-600 hover:text-blue-800 inline-flex items-center mb-4" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
      返回订单列表
    <% end %>
    
    <div class="flex justify-between items-start">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">订单详情</h1>
        <p class="text-gray-600 mt-2">订单号: #<%= @order.id.to_s.rjust(6, '0') %></p>
      </div>
      
      <!-- 状态修改 -->
      <div class="bg-white rounded-lg shadow-lg p-4">
        <p class="text-sm text-gray-600 mb-2">订单状态</p>
        <div class="flex items-center space-x-2">
          <span class="px-4 py-2 inline-flex text-sm font-semibold rounded-full
            <%= case @order.status
                when 'pending' then 'bg-yellow-100 text-yellow-800'
                when 'paid' then 'bg-green-100 text-green-800'
                when 'shipped' then 'bg-blue-100 text-blue-800'
                when 'completed' then 'bg-gray-100 text-gray-800'
                end %>">
            <%= case @order.status
                when 'pending' then '待支付'
                when 'paid' then '已支付'
                when 'shipped' then '已发货'
                when 'completed' then '已完成'
                end %>
          </span>
          
          <!-- 状态修改按钮 -->
          <div class="relative inline-block text-left">
            <button type="button" class="inline-flex justify-center items-center px-3 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none" id="status-menu-button" onclick="toggleStatusMenu()">
              修改状态
              <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            
            <div class="hidden origin-top-right absolute right-0 mt-2 w-40 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 z-10" id="status-menu">
              <div class="py-1" role="menu">
                <% ['pending', 'paid', 'shipped', 'completed'].each do |status| %>
                  <% next if status == @order.status %>
                  <%= button_to update_status_admin_order_path(@order, status: status), method: :patch, class: "block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100", form: { data: { turbo_confirm: "确认将订单状态改为「#{case status when 'pending' then '待支付' when 'paid' then '已支付' when 'shipped' then '已发货' when 'completed' then '已完成' end}」吗？" } } do %>
                    <%= case status
                        when 'pending' then '待支付'
                        when 'paid' then '已支付'
                        when 'shipped' then '已发货'
                        when 'completed' then '已完成'
                        end %>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- 左侧：客户信息 + 商品明细 -->
    <div class="lg:col-span-2 space-y-6">
      <!-- 客户信息区 -->
      <div class="bg-white rounded-lg shadow-lg p-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center">
          <svg class="w-6 h-6 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
          客户信息
        </h2>
        
        <div class="grid grid-cols-2 gap-4">
          <div>
            <p class="text-sm text-gray-600">姓名</p>
            <p class="text-base font-medium text-gray-900 mt-1"><%= @order.name %></p>
          </div>
          <div>
            <p class="text-sm text-gray-600">手机号码</p>
            <p class="text-base font-medium text-gray-900 mt-1"><%= @order.phone %></p>
          </div>
          <div class="col-span-2">
            <p class="text-sm text-gray-600">Email</p>
            <p class="text-base font-medium text-gray-900 mt-1"><%= @order.email %></p>
          </div>
          <div class="col-span-2">
            <p class="text-sm text-gray-600">配送地址</p>
            <p class="text-base text-gray-900 mt-1"><%= @order.address %></p>
          </div>
        </div>
      </div>

      <!-- 商品明细区 -->
      <div class="bg-white rounded-lg shadow-lg p-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center">
          <svg class="w-6 h-6 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
          </svg>
          商品明细
        </h2>
        
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">商品</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">单价</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">数量</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">小计</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <% @order.order_items.includes(:product).each do |item| %>
                <tr>
                  <td class="px-4 py-4">
                    <div class="flex items-center">
                      <% if item.product.image.attached? %>
                        <%= image_tag item.product.image, class: "h-12 w-12 object-cover rounded" %>
                      <% else %>
                        <div class="h-12 w-12 bg-gray-200 rounded"></div>
                      <% end %>
                      <div class="ml-3">
                        <p class="text-sm font-medium text-gray-900"><%= item.product.name %></p>
                      </div>
                    </div>
                  </td>
                  <td class="px-4 py-4 text-center text-sm text-gray-900">
                    ¥<%= number_to_currency(item.price, unit: "", precision: 2) %>
                  </td>
                  <td class="px-4 py-4 text-center text-sm text-gray-900">
                    <%= item.quantity %>
                  </td>
                  <td class="px-4 py-4 text-right text-sm font-semibold text-gray-900">
                    ¥<%= number_to_currency(item.subtotal, unit: "", precision: 2) %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- 右侧：订单信息 -->
    <div class="lg:col-span-1">
      <div class="bg-white rounded-lg shadow-lg p-6 sticky top-20">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">订单信息</h2>
        
        <div class="space-y-4">
          <div>
            <p class="text-sm text-gray-600">订单编号</p>
            <p class="text-lg font-bold text-blue-600 mt-1">#<%= @order.id.to_s.rjust(6, '0') %></p>
          </div>
          
          <div>
            <p class="text-sm text-gray-600">下单时间</p>
            <p class="text-base text-gray-900 mt-1"><%= @order.created_at.strftime('%Y-%m-%d %H:%M:%S') %></p>
          </div>
          
          <div class="border-t pt-4">
            <div class="flex justify-between text-gray-600 mb-2">
              <span>商品总额</span>
              <span>¥<%= number_to_currency(@order.total_price, unit: "", precision: 2) %></span>
            </div>
            <div class="flex justify-between text-gray-600 mb-4">
              <span>运费</span>
              <span>免运费</span>
            </div>
            <div class="flex justify-between items-center border-t pt-4">
              <span class="text-lg font-semibold text-gray-900">订单总计</span>
              <span class="text-2xl font-bold text-blue-600">
                ¥<%= number_to_currency(@order.total_price, unit: "", precision: 2) %>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function toggleStatusMenu() {
    const menu = document.getElementById('status-menu');
    menu.classList.toggle('hidden');
  }
  
  // 点击外部关闭菜单
  document.addEventListener('click', function(event) {
    const button = document.getElementById('status-menu-button');
    const menu = document.getElementById('status-menu');
    if (!button.contains(event.target) && !menu.contains(event.target)) {
      menu.classList.add('hidden');
    }
  });
</script>
