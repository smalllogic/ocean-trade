<div class="w-full">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Inquiries / Messages</h1>
    <div class="flex space-x-2">
      <span class="px-3 py-1 bg-blue-100 text-blue-800 text-xs font-bold rounded-full">
        Total: <%= @inquiries.count %>
      </span>
      <span class="px-3 py-1 bg-yellow-100 text-yellow-800 text-xs font-bold rounded-full">
        Unread: <%= @inquiries.unread.count %>
      </span>
    </div>
  </div>

  <% if @inquiries.any? %>
    <div class="bg-white shadow-lg rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Customer</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Subject</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @inquiries.each do |inquiry| %>
            <tr class="hover:bg-gray-50 <%= 'font-bold' if inquiry.unread? %>">
              <td class="px-6 py-4 whitespace-nowrap">
                <% if inquiry.unread? %>
                  <span class="flex h-2 w-2 rounded-full bg-blue-600"></span>
                <% else %>
                  <span class="text-gray-400">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/></svg>
                  </span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-900"><%= inquiry.name %></div>
                <div class="text-xs text-gray-500"><%= inquiry.email %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-900"><%= inquiry.subject %></div>
                <div class="text-xs text-gray-500 truncate max-w-xs"><%= truncate(inquiry.message, length: 50) %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= inquiry.created_at.strftime("%Y-%m-%d %H:%M") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <div class="flex justify-end space-x-2">
                  <%= link_to "View", admin_inquiry_path(inquiry), class: "text-blue-600 hover:text-blue-900" %>
                  <% if inquiry.unread? %>
                    <%= button_to "Mark as Read", mark_as_read_admin_inquiry_path(inquiry), method: :patch, class: "text-green-600 hover:text-green-900" %>
                  <% end %>
                  <%= link_to "Delete", admin_inquiry_path(inquiry), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-900" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white shadow-lg rounded-lg p-12 text-center text-gray-500">
      No messages yet.
    </div>
  <% end %>
</div>
