<div class="w-full">
  <div class="bg-white shadow-lg rounded-lg p-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">管理员后台</h1>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- 统计卡片 -->
      <div class="bg-blue-50 border-l-4 border-blue-500 p-6 rounded">
        <h3 class="text-lg font-semibold text-blue-900 mb-2">产品总数</h3>
        <p class="text-3xl font-bold text-blue-600"><%= Product.count %></p>
      </div>
      
      <div class="bg-green-50 border-l-4 border-green-500 p-6 rounded">
        <h3 class="text-lg font-semibold text-green-900 mb-2">显示中</h3>
        <p class="text-3xl font-bold text-green-600"><%= Product.visible.count %></p>
      </div>
      
      <div class="bg-purple-50 border-l-4 border-purple-500 p-6 rounded">
        <h3 class="text-lg font-semibold text-purple-900 mb-2">已隐藏</h3>
        <p class="text-3xl font-bold text-purple-600"><%= Product.hidden.count %></p>
      </div>
    </div>
    
    <div class="mt-8">
      <h2 class="text-2xl font-semibold mb-4">快速操作</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <%= link_to admin_products_path, class: "bg-blue-500 hover:bg-blue-600 text-white font-bold py-4 px-6 rounded-lg text-center transition" do %>
          📦 管理产品
        <% end %>
        
        <%= link_to "#", class: "bg-green-500 hover:bg-green-600 text-white font-bold py-4 px-6 rounded-lg text-center transition" do %>
          👥 管理用户
        <% end %>
        
        <%= link_to "#", class: "bg-purple-500 hover:bg-purple-600 text-white font-bold py-4 px-6 rounded-lg text-center transition" do %>
          ⚙️ 系统设置
        <% end %>
        
        <%= link_to "#", class: "bg-orange-500 hover:bg-orange-600 text-white font-bold py-4 px-6 rounded-lg text-center transition" do %>
          📝 查看日志
        <% end %>
      </div>
    </div>
  </div>
</div>
