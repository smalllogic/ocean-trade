<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "OceanTrade Admin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100 font-sans antialiased">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="w-64 bg-gray-900 text-white flex-shrink-0 flex flex-col fixed inset-y-0 left-0 z-50 transition-all duration-300">
        <div class="p-6 flex items-center justify-between border-b border-gray-800">
          <%= link_to admin_root_path, class: "flex items-center space-x-3" do %>
            <div class="w-8 h-8 bg-blue-600 rounded flex items-center justify-center font-bold text-lg">O</div>
            <span class="text-xl font-bold tracking-wider">OCEAN TRADE</span>
          <% end %>
        </div>

        <nav class="flex-grow p-4 space-y-2 overflow-y-auto mt-4">
          <%= link_to admin_root_path, class: "flex items-center space-x-3 p-3 rounded-lg transition #{current_page?(admin_root_path) ? 'bg-blue-600 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white'}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
            <span class="font-medium">Dashboard</span>
          <% end %>

          <%= link_to admin_categories_path, class: "flex items-center space-x-3 p-3 rounded-lg transition #{params[:controller] == 'admin/categories' ? 'bg-blue-600 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white'}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path></svg>
            <span class="font-medium">Categories</span>
          <% end %>

          <%= link_to admin_products_path, class: "flex items-center space-x-3 p-3 rounded-lg transition #{params[:controller] == 'admin/products' ? 'bg-blue-600 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white'}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
            <span class="font-medium">Products</span>
          <% end %>

          <%= link_to admin_orders_path, class: "flex items-center space-x-3 p-3 rounded-lg transition #{params[:controller] == 'admin/orders' ? 'bg-blue-600 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white'}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
            <span class="font-medium">Orders</span>
          <% end %>

          <%= link_to admin_inquiries_path, class: "flex items-center space-x-3 p-3 rounded-lg transition #{params[:controller] == 'admin/inquiries' ? 'bg-blue-600 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white'}" do %>
            <div class="relative">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              <% unread_count = Inquiry.unread.count %>
              <% if unread_count > 0 %>
                <span class="absolute -top-1 -right-1 bg-red-500 text-white text-[8px] font-bold rounded-full h-3 w-3 flex items-center justify-center"><%= unread_count %></span>
              <% end %>
            </div>
            <span class="font-medium">Inquiries</span>
          <% end %>
        </nav>

        <div class="p-4 border-t border-gray-800">
          <%= link_to root_path, class: "flex items-center space-x-3 p-3 text-gray-400 hover:text-white transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            <span class="font-medium">Back to Shop</span>
          <% end %>
          <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "flex items-center space-x-3 p-3 text-red-400 hover:text-red-300 transition mt-2" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
            <span class="font-medium">Logout</span>
          <% end %>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="flex-grow ml-64 p-8">
        <% if flash.any? %>
          <div class="mb-6">
            <%= render "shared/flash" %>
          </div>
        <% end %>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
