<footer class="bg-slate-950 text-slate-400 pt-20 pb-10 border-t border-slate-800">
  <div class="container mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16 mb-20">
      <!-- Company Info -->
      <div class="space-y-8">
        <%= link_to root_path, class: "inline-block" do %>
          <%= image_tag "logo.jpg", class: "h-12 w-auto border border-slate-800 rounded opacity-90", alt: "Ocean Trade Logo" %>
        <% end %>
        <p class="text-sm leading-relaxed font-medium text-slate-500">
          US CHINA OCEAN INTERNATIONAL TRADE INC. 
          Professional industrial safety protection equipment supplier. We provide the highest standard of safety products for global engineering construction, factory manufacturing, and logistics warehousing.
        </p>
        <div class="flex space-x-5">
          <a href="#" class="text-slate-500 hover:text-orange-500 transition-colors">
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="text-white font-black text-xs uppercase tracking-[0.2em] mb-10 border-l-4 border-orange-500 pl-4">Product Center</h4>
        <ul class="space-y-4 font-bold text-sm tracking-wide">
          <% Category.where(parent_id: nil).limit(4).each do |cat| %>
            <li><%= link_to cat.name, products_path(category_id: cat.id), class: "hover:text-orange-500 transition-colors" %></li>
          <% end %>
          <li><%= link_to "All Products", products_path, class: "hover:text-orange-500 transition-colors text-slate-500" %></li>
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h4 class="text-white font-black text-xs uppercase tracking-[0.2em] mb-10 border-l-4 border-orange-500 pl-4">Customer Service</h4>
        <ul class="space-y-4 font-bold text-sm tracking-wide">
          <li><%= link_to "About Us", contact_us_path, class: "hover:text-orange-500 transition-colors" %></li>
          <li><%= link_to "Help Center", help_center_path, class: "hover:text-orange-500 transition-colors" %></li>
          <li><%= link_to "Refund Policy", refund_policy_path, class: "hover:text-orange-500 transition-colors" %></li>
          <li><%= link_to "Contact Expert", contact_us_path, class: "text-orange-500 hover:text-orange-400" %></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="text-white font-black text-xs uppercase tracking-[0.2em] mb-10 border-l-4 border-orange-500 pl-4">Contact Info</h4>
        <div class="space-y-6">
          <div class="flex items-start space-x-4">
            <svg class="w-6 h-6 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="text-sm font-bold leading-tight">US CHINA OCEAN INTERNATIONAL TRADE INC</span>
          </div>
          <div class="flex items-center space-x-4">
            <svg class="w-6 h-6 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <span class="text-sm font-bold">support@oceantrade.com</span>
          </div>
        </div>
      </div>
    </div>

    <div class="pt-10 border-t border-slate-900 flex flex-col md:flex-row justify-between items-center text-[10px] font-bold text-slate-600 tracking-widest uppercase">
      <p>&copy; <%= Time.current.year %> US CHINA OCEAN INTERNATIONAL TRADE INC. ALL RIGHTS RESERVED.</p>
      <div class="flex space-x-8 mt-4 md:mt-0">
        <a href="#" class="hover:text-slate-400">Terms of Service</a>
        <a href="#" class="hover:text-slate-400">Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>
