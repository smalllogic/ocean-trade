<nav class="bg-white shadow-lg fixed top-0 left-0 right-0 z-50" data-controller="mobile-menu">
  <div class="container mx-auto px-4">
    <div class="flex justify-between items-center h-16">
      <!-- 左侧导航 -->
      <div class="flex items-center space-x-8">
        <%= link_to root_path, class: "flex items-center" do %>
          <img src="/logo.jpg" class="h-10 w-auto" alt="Fandisha Logo">
        <% end %>
        
        <div class="hidden md:flex space-x-6">
          <%= link_to "首页", root_path, class: "text-gray-700 hover:text-blue-600 font-medium transition" %>
          <%= link_to "产品", products_path, class: "text-gray-700 hover:text-blue-600 font-medium transition" %>
          <%= link_to "服务", "#", class: "text-gray-700 hover:text-blue-600 font-medium transition" %>
          <%= link_to "关于", "#", class: "text-gray-700 hover:text-blue-600 font-medium transition" %>
          <% if user_signed_in? && current_user.admin? %>
            <%= link_to "管理后台", admin_root_path, class: "text-purple-600 hover:text-purple-800 font-semibold transition" %>
          <% end %>
        </div>
      </div>
      
      <!-- 右侧用户区域 -->
      <div class="flex items-center space-x-4">
        <!-- 购物车图标 -->
        <%= link_to cart_path, class: "relative text-gray-700 hover:text-blue-600 transition" do %>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
          <% if current_cart.total_quantity > 0 %>
            <span class="absolute -top-2 -right-2 bg-red-500 text-white text-xs font-bold rounded-full h-5 w-5 flex items-center justify-center">
              <%= current_cart.total_quantity %>
            </span>
          <% end %>
        <% end %>
        
        <% if user_signed_in? %>
          <% if current_user.admin? %>
            <span class="bg-purple-100 text-purple-800 text-xs font-semibold px-2 py-1 rounded">管理员</span>
          <% end %>
          <span class="text-gray-600">欢迎, <%= current_user.email %></span>
          <%= link_to "退出", destroy_user_session_path, data: { turbo_method: :delete }, 
              class: "bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg transition" %>
        <% else %>
          <%= link_to "登录", new_user_session_path, 
              class: "text-gray-700 hover:text-blue-600 font-medium transition" %>
          <%= link_to "注册", new_user_registration_path, 
              class: "bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition" %>
        <% end %>
      </div>
      
      <!-- 移动端菜单按钮 -->
      <div class="md:hidden">
        <button type="button" class="text-gray-700 hover:text-blue-600" data-action="click->mobile-menu#toggle">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
    
    <!-- 移动端菜单 -->
    <div class="hidden md:hidden pb-4" id="mobile-menu">
      <div class="flex flex-col space-y-2">
        <%= link_to "首页", root_path, class: "text-gray-700 hover:text-blue-600 py-2" %>
        <%= link_to "产品", products_path, class: "text-gray-700 hover:text-blue-600 py-2" %>
        <%= link_to "服务", "#", class: "text-gray-700 hover:text-blue-600 py-2" %>
        <%= link_to "关于", "#", class: "text-gray-700 hover:text-blue-600 py-2" %>
        <% if user_signed_in? && current_user.admin? %>
          <%= link_to "管理后台", admin_root_path, class: "text-purple-600 hover:text-purple-800 font-semibold py-2" %>
        <% end %>
      </div>
    </div>
  </div>
</nav>
