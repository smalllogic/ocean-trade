<div class="bg-white min-h-screen">
  <!-- Page Header -->
  <div class="bg-slate-900 pt-32 pb-20">
    <div class="container mx-auto px-6 lg:px-12">
      <% if @current_category.present? %>
        <nav class="flex items-center space-x-2 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-6">
          <%= link_to "Home", root_path, class: "hover:text-white transition-colors" %>
          <span>/</span>
          <% @current_category.path_from_root[0...-1].each do |p_cat| %>
            <%= link_to p_cat.name, products_path(category_id: p_cat.id), class: "hover:text-white transition-colors" %>
            <span>/</span>
          <% end %>
          <span class="text-orange-500"><%= @current_category.name %></span>
        </nav>
        <h1 class="text-5xl md:text-7xl font-black text-white uppercase tracking-tighter leading-none">
          <%= @current_category.name %>
        </h1>
      <% else %>
        <h1 class="text-5xl md:text-7xl font-black text-white uppercase tracking-tighter leading-none">
          全部防护产品
        </h1>
        <p class="text-slate-400 mt-6 font-bold text-sm tracking-widest uppercase">Browse our industrial safety collection</p>
      <% end %>
    </div>
  </div>

  <div class="container mx-auto px-6 lg:px-12 py-20">
    <div class="flex flex-col lg:flex-row gap-16">
      
      <!-- Sidebar Filters -->
      <aside class="w-full lg:w-72 flex-shrink-0">
        <div class="sticky top-32 space-y-12">
          <!-- Category Tree -->
          <div>
            <h3 class="text-xs font-black uppercase tracking-[0.3em] text-slate-900 mb-8 border-l-4 border-orange-600 pl-4">产品目录</h3>
            <div class="space-y-2">
              <%= link_to "显示所有产品", products_path, class: "block py-2 text-sm font-bold #{!params[:category_id] ? 'text-orange-600' : 'text-slate-500 hover:text-orange-600'} transition-colors" %>
              <% Category.where(parent_id: nil).order(:id).each do |top_cat| %>
                <div class="space-y-1">
                  <%= link_to top_cat.name, products_path(category_id: top_cat.id), 
                      class: "block py-2 text-sm font-bold #{params[:category_id].to_i == top_cat.id ? 'text-orange-600' : 'text-slate-500 hover:text-orange-600'} transition-colors" %>
                  
                  <% if params[:category_id].present? && (@current_category&.path_from_root&.map(&:id)&.include?(top_cat.id)) %>
                    <div class="pl-4 border-l border-slate-100 ml-1 space-y-1">
                      <% top_cat.children.order(:id).each do |sub_cat| %>
                        <%= link_to sub_cat.name, products_path(category_id: sub_cat.id), 
                            class: "block py-1.5 text-[13px] font-bold #{params[:category_id].to_i == sub_cat.id ? 'text-orange-600' : 'text-slate-400 hover:text-orange-600'} transition-colors" %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>

          <!-- Contact Widget -->
          <div class="bg-slate-50 p-8 border border-slate-100">
            <h4 class="text-sm font-black uppercase tracking-tight mb-4">需要批量定制？</h4>
            <p class="text-xs text-slate-500 font-medium leading-relaxed mb-6">针对大型工厂及工程项目，我们提供极具竞争力的阶梯报价与定制服务。</p>
            <%= link_to "获取大宗报价", contact_us_path, class: "block text-center py-3 bg-slate-900 text-white text-[10px] font-black uppercase tracking-widest hover:bg-orange-600 transition-colors" %>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <div class="flex-grow">
        <% if @products.any? %>
          <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-x-8 gap-y-16">
            <% @products.each do |product| %>
              <div class="group">
                <%= link_to product_path(product), class: "block" do %>
                  <div class="relative aspect-square bg-slate-50 overflow-hidden mb-6 border border-slate-100 group-hover:border-orange-600 transition-colors duration-500">
                    <% if product.images.attached? %>
                      <%= image_tag product.images.first, class: "w-full h-full object-cover grayscale-[0.2] group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" %>
                    <% else %>
                      <div class="w-full h-full flex items-center justify-center">
                        <svg class="w-12 h-12 text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                      </div>
                    <% end %>
                    <div class="absolute bottom-4 left-4">
                      <span class="bg-orange-600 text-white text-[10px] font-black px-3 py-1.5 tracking-tighter shadow-xl">
                        $<%= number_to_currency(product.min_price, unit: "", precision: 2) %>
                      </span>
                    </div>
                  </div>
                  
                  <h3 class="text-lg font-black text-slate-900 uppercase tracking-tight group-hover:text-orange-600 transition-colors mb-2">
                    <%= product.name %>
                  </h3>
                  
                  <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-4">
                    <%= product.category&.name %>
                  </p>
                  
                  <div class="flex items-center justify-between">
                    <div class="h-1 w-8 bg-slate-200 group-hover:w-16 group-hover:bg-orange-500 transition-all duration-500"></div>
                    <span class="text-[10px] font-black uppercase tracking-widest text-slate-900 opacity-0 group-hover:opacity-100 transition-opacity">View Details</span>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="py-20 text-center border-2 border-dashed border-slate-100">
            <div class="text-4xl mb-4">📦</div>
            <h2 class="text-xl font-black text-slate-900 uppercase">暂无此类产品</h2>
            <p class="text-slate-400 mt-2 font-bold text-xs uppercase">Coming Soon / Under Update</p>
          </div>
        <% end %>
      </div>

    </div>
  </div>
</div>
