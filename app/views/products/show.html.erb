<div class="w-full max-w-7xl mx-auto px-4 py-8">
  <!-- Breadcrumb / Back button -->
  <nav class="flex mb-8 items-center text-sm font-medium text-gray-500 overflow-x-auto whitespace-nowrap pb-2 md:pb-0">
    <%= link_to "Home", root_path, class: "hover:text-emerald-600 transition-colors" %>
    <svg class="w-4 h-4 mx-2 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
    </svg>
    <%= link_to "Products", products_path, class: "hover:text-emerald-600 transition-colors" %>
    <svg class="w-4 h-4 mx-2 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
    </svg>
    <span class="text-gray-900 font-semibold truncate"><%= @product.name %></span>
  </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start">
      <!-- Left: Image Gallery -->
      <div class="lg:col-span-7 xl:col-span-8 lg:sticky lg:top-24">
        <div class="flex flex-col md:flex-row-reverse gap-3 md:gap-4">
          <!-- Main Image -->
          <div class="w-full">
          <div id="image-ambient" class="group relative aspect-[4/5] md:aspect-square w-full overflow-hidden rounded-3xl bg-gray-50 border border-gray-100 shadow-sm transition-all duration-500">
            <% if @product.images.attached? %>
              <%= image_tag @product.images.first, 
                  class: "w-full h-full object-cover transition-all duration-700 ease-out transform group-hover:scale-110",
                  id: "main-product-image",
                  data: { main_image: true },
                  alt: @product.name %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center bg-gray-50 text-gray-300">
                <svg class="w-20 h-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
              </div>
            <% end %>
            
            <!-- Ambient Light Effect -->
            <span class="pointer-events-none absolute inset-0 mix-blend-screen opacity-0 group-hover:opacity-100 transition-opacity duration-700" style="background: radial-gradient(300px at var(--lx,50%) var(--ly,50%), rgba(16, 185, 129, 0.15), transparent 70%);"></span>
            
            <!-- Floating Zoom Indicator -->
            <div class="absolute bottom-6 right-6 p-3 rounded-2xl bg-white/80 backdrop-blur-md border border-white shadow-lg opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-y-4 group-hover:translate-y-0 hidden md:block">
              <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"></path>
              </svg>
            </div>
          </div>
        </div>

        <!-- Thumbnails List (Horizontal on Mobile, Vertical on MD+) -->
        <% if @product.images.attached? && @product.images.count > 1 %>
          <div class="flex md:flex-col gap-3 overflow-x-auto md:overflow-y-auto no-scrollbar py-2 md:py-0 w-full md:w-20 lg:w-24 shrink-0 h-fit">
            <% @product.images.each_with_index do |image, index| %>
              <button type="button" 
                      class="thumbnail-btn flex-shrink-0 relative w-16 md:w-full aspect-square rounded-2xl overflow-hidden border-2 transition-all duration-300 group <%= index == 0 ? 'border-emerald-600 ring-4 ring-emerald-50' : 'border-gray-100' %>"
                      onclick="changeMainImage(this, '<%= url_for(image) %>')">
                <%= image_tag image, class: "w-full h-full object-cover transition-transform group-hover:scale-110" %>
              </button>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Right: Product Information & Checkout -->
    <div class="lg:col-span-5 xl:col-span-4">
      <div class="space-y-10">
        <!-- Title & Badges -->
        <div>
          <div class="flex flex-wrap gap-2 mb-4">
            <% if @product.category %>
              <span class="bg-emerald-50 text-emerald-700 text-[10px] uppercase tracking-widest font-black px-2.5 py-1 rounded-full border border-emerald-100">
                <%= @product.category.name %>
              </span>
            <% end %>
            <% if @product.variants.active.any? %>
              <span class="bg-blue-50 text-blue-700 text-[10px] uppercase tracking-widest font-black px-2.5 py-1 rounded-full border border-blue-100">
                In Stock
              </span>
            <% end %>
          </div>
          <h1 class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight leading-none mb-6">
            <%= @product.name %>
          </h1>
          <div class="flex items-center space-x-4">
            <% if @product.variants.active.any? %>
              <div id="price-display" class="text-3xl font-black text-gray-900 flex items-baseline">
                <span class="text-xl mr-0.5">$</span>
                <span><%= number_to_currency(@product.min_price, unit: "", precision: 2) %></span>
                <% if @product.min_price != @product.max_price %>
                  <span class="text-gray-400 font-normal text-lg ml-2">— $<%= number_to_currency(@product.max_price, unit: "", precision: 2) %></span>
                <% end %>
              </div>
            <% else %>
              <div class="text-3xl font-black text-gray-900 flex items-baseline">
                <span class="text-xl mr-0.5">$</span>
                <span><%= number_to_currency(@product.price, unit: "", precision: 2) %></span>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Summary & Divider -->
        <% if @product.summary.present? %>
          <div class="relative">
            <div class="absolute -left-6 top-0 bottom-0 w-1 bg-emerald-500 rounded-full"></div>
            <p class="text-lg text-gray-600 font-medium leading-relaxed italic">
              "<%= @product.summary %>"
            </p>
          </div>
        <% end %>

        <!-- Product Actions Form -->
        <div class="bg-gray-50/50 p-6 md:p-8 rounded-[2rem] border border-gray-100 shadow-sm space-y-8">
          <%= form_with url: add_to_cart_product_path(@product), method: :post, class: "space-y-8" do |f| %>
            <% if @product.variants.active.any? %>
              <!-- Variant Selector -->
              <div>
                <div class="flex justify-between items-end mb-4">
                  <label class="block text-xs font-black text-gray-400 uppercase tracking-widest">Select Configuration</label>
                  <span class="text-xs text-gray-400 italic">2二选一 filling 1</span>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 md:gap-4">
                  <% @product.variants.active.ordered.each_with_index do |variant, index| %>
                    <label class="variant-option relative group cursor-pointer" 
                           onclick="updatePrice('<%= number_to_currency(variant.price, unit: '$', precision: 2) %>'); selectVariant(this)">
                      <input type="radio" name="variant_id" value="<%= variant.id %>" class="sr-only peer" <%= 'checked' if index == 0 %>>
                      <div class="p-3 md:p-4 border-2 rounded-2xl bg-white transition-all duration-300 peer-checked:border-emerald-600 peer-checked:ring-4 peer-checked:ring-emerald-50 peer-checked:shadow-md hover:shadow-sm border-gray-100 hover:border-emerald-300">
                        <div class="flex sm:flex-col items-center justify-between sm:justify-center text-left sm:text-center">
                          <div class="flex flex-col">
                            <span class="block text-sm font-black text-gray-900 group-hover:text-emerald-700 transition-colors"><%= variant.title %></span>
                            <div class="mt-1 sm:mt-2 space-y-0.5">
                              <% if variant.length.present? %>
                                <span class="block text-[10px] uppercase font-bold text-gray-400 tracking-tighter">Len: <%= variant.length %></span>
                              <% elsif variant.capacity.present? %>
                                <span class="block text-[10px] uppercase font-bold text-gray-400 tracking-tighter">Cap: <%= variant.capacity %></span>
                              <% end %>
                            </div>
                          </div>
                          <span class="block text-xs font-black text-emerald-600 sm:mt-1">$<%= number_to_currency(variant.price, unit: "", precision: 2) %></span>
                        </div>
                      </div>
                      <!-- Checkmark badge -->
                      <div class="absolute -top-2 -right-2 bg-emerald-600 text-white p-1 rounded-full opacity-0 peer-checked:opacity-100 scale-50 peer-checked:scale-100 transition-all duration-300 shadow-lg">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                        </svg>
                      </div>
                    </label>
                  <% end %>
                </div>
              </div>
              
              <!-- Buy Button -->
              <div class="pt-2">
                <%= f.button class: "group w-full relative overflow-hidden bg-gray-900 text-white py-6 rounded-2xl transition-all duration-500 hover:bg-emerald-600 hover:shadow-2xl hover:shadow-emerald-200 active:scale-95 focus:ring-4 focus:ring-emerald-100 outline-none" do %>
                  <div class="relative z-10 flex items-center justify-center space-x-3 text-lg font-black tracking-tight">
                    <span>Add to Bag</span>
                    <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                    </svg>
                  </div>
                <% end %>
                <p class="text-center text-[10px] text-gray-400 uppercase tracking-widest font-bold mt-4">Free premium shipping included</p>
              </div>
            <% else %>
              <div class="p-8 bg-red-50/50 border border-red-100 text-red-700 rounded-3xl text-center flex flex-col items-center">
                <svg class="w-10 h-10 mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                </svg>
                <span class="font-black uppercase tracking-widest text-sm">Product Temporarily Offline</span>
                <p class="text-xs mt-1 text-red-500">Contact support to check availability</p>
              </div>
            <% end %>
          <% end %>
        </div>

        <!-- Description Accordion Style (Simplified) -->
        <div class="space-y-6 pt-4">
          <div class="group border-t border-gray-100 pt-6">
            <h2 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-4">Master Storyteller's Description</h2>
            <% if @product.description.present? %>
              <div class="text-gray-600 leading-relaxed text-base font-medium whitespace-pre-wrap max-h-48 overflow-y-auto no-scrollbar pb-2">
                <%= @product.description %>
              </div>
            <% else %>
              <p class="text-gray-300 italic text-sm">No chronicle exists for this treasure yet.</p>
            <% end %>
          </div>
          
          <!-- Quick Specs List -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4 pt-6 border-t border-gray-100">
            <div>
              <span class="block text-[10px] uppercase font-black text-gray-300 tracking-widest">Serial Code</span>
              <span class="text-sm font-bold text-gray-900 mt-0.5 inline-block">FD-<%= @product.id.to_s.rjust(5, '0') %></span>
            </div>
            <div>
              <span class="block text-[10px] uppercase font-black text-gray-300 tracking-widest">Added to Vault</span>
              <span class="text-sm font-bold text-gray-900 mt-0.5 inline-block"><%= @product.created_at.strftime("%b %d, %Y") %></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Recommended Products: Aesthetic Grid -->
  <div class="mt-32 pt-16 border-t border-gray-100">
    <div class="flex items-end justify-between mb-12">
      <div>
        <h2 class="text-3xl font-black text-gray-900 tracking-tighter">You Might Also Covet</h2>
        <p class="text-gray-400 text-sm font-medium mt-2 italic">Specially curated pieces from our exclusive collections</p>
      </div>
      <%= link_to products_path, class: "hidden md:flex items-center text-xs font-black uppercase tracking-widest text-emerald-600 hover:text-emerald-700 transition-colors" do %>
        View Collection
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      <% end %>
    </div>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-8">
      <% Product.visible.where.not(id: @product.id).limit(4).each_with_index do |rp, i| %>
        <%= link_to product_path(rp), class: "group reveal reveal-delay-#{i}" do %>
          <div class="relative bg-white rounded-3xl overflow-hidden border border-gray-100 shadow-sm transition-all duration-500 hover:shadow-2xl hover:-translate-y-2">
            <div class="aspect-[4/5] bg-gray-50 overflow-hidden relative">
              <% if rp.images.attached? %>
                <%= image_tag rp.images.first, class: "w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" %>
              <% end %>
              <!-- Floating Price Badge -->
              <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-md px-3 py-1.5 rounded-2xl shadow-sm border border-white">
                <span class="text-xs font-black text-gray-900 tracking-tight">$<%= number_to_currency(rp.min_price, unit: "", precision: 0) %></span>
              </div>
            </div>
            <div class="p-6">
              <h3 class="font-black text-gray-900 truncate mb-1 text-sm"><%= rp.name %></h3>
              <p class="text-gray-400 text-[10px] uppercase font-bold tracking-widest truncate">Explore Essence →</p>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

  /* Smooth Entrance for Related */
  .reveal { opacity: 0; transform: translateY(20px); transition: all 0.8s ease-out; }
  .reveal.revealed { opacity: 1; transform: translateY(0); }
  .reveal-delay-0 { transition-delay: 0.1s; }
  .reveal-delay-1 { transition-delay: 0.2s; }
  .reveal-delay-2 { transition-delay: 0.3s; }
  .reveal-delay-3 { transition-delay: 0.4s; }

  @keyframes pulse-emerald {
    0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
    70% { box-shadow: 0 0 0 10px rgba(16, 185, 129, 0); }
    100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
  }
</style>

<script>
  function updatePrice(price) {
    const container = document.getElementById('price-display');
    if (!container) return;
    const priceEl = container.querySelector('span:nth-child(2)');
    if (priceEl) {
      container.classList.add('scale-105', 'opacity-50');
      setTimeout(() => {
        priceEl.innerText = price.replace('$', '');
        container.classList.remove('scale-105', 'opacity-50');
      }, 150);
    }
  }

  function selectVariant(label) {
    // Handling is mostly done via peer-* in Tailwind
  }

  function changeMainImage(btn, src) {
    const mainImg = document.getElementById('main-product-image');
    if (mainImg) {
      mainImg.classList.add('opacity-0', 'scale-95');
      setTimeout(() => {
        mainImg.src = src;
        mainImg.classList.remove('opacity-0', 'scale-95');
      }, 250);
    }
    
    document.querySelectorAll('.thumbnail-btn').forEach(el => {
      el.classList.remove('border-emerald-600', 'ring-4', 'ring-emerald-50');
      el.classList.add('border-gray-100');
    });
    btn.classList.remove('border-gray-100');
    btn.classList.add('border-emerald-600', 'ring-4', 'ring-emerald-50');
  }

  (function(){
    let scrollHandler = null;
    let mouseHandler = null;

    function initShow(){
      const ambient = document.getElementById('image-ambient');
      if (!ambient) return;

      mouseHandler = (e)=>{
        const rect = ambient.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        ambient.style.setProperty('--lx', x + '%');
        ambient.style.setProperty('--ly', y + '%');
      };
      ambient.addEventListener('mousemove', mouseHandler);

      // Related products scroll reveal
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
            }
          });
        }, { threshold: 0.1 });
        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
      } else {
        document.querySelectorAll('.reveal').forEach(el => el.classList.add('revealed'));
      }
    }

    document.addEventListener('turbo:load', initShow);
    document.addEventListener('turbo:render', initShow);
  })();
</script>
