<div class="bg-white min-h-screen pt-32 pb-24">
  <div class="container mx-auto px-6 lg:px-12">
    <!-- Breadcrumb / Back button -->
    <nav class="flex items-center space-x-3 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-16 overflow-x-auto whitespace-nowrap pb-4 md:pb-0">
      <%= link_to "Home", root_path, class: "hover:text-orange-600 transition-colors" %>
      <span class="text-slate-200">/</span>
      <%= link_to "Products", products_path, class: "hover:text-orange-600 transition-colors" %>
      <span class="text-slate-200">/</span>
      <span class="text-orange-500 truncate"><%= @product.name %></span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
      <!-- Left: Image Gallery -->
      <div class="lg:col-span-5 lg:sticky lg:top-32">
        <div class="space-y-6 max-w-md mx-auto lg:mx-0">
          <!-- Main Image -->
          <div class="relative aspect-square w-full bg-slate-50 border border-slate-100 overflow-hidden group">
            <% if @product.images.attached? %>
              <%= image_tag @product.images.first, 
                  class: "w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-110 grayscale-[0.3] group-hover:grayscale-0",
                  id: "main-product-image",
                  alt: @product.name %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center text-slate-200">
                <svg class="w-24 h-24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
              </div>
            <% end %>
            <div class="absolute inset-0 border-[30px] border-white/5 pointer-events-none"></div>
          </div>

          <!-- Thumbnails -->
          <% if @product.images.attached? && @product.images.count > 1 %>
            <div class="grid grid-cols-5 gap-4">
              <% @product.images.each_with_index do |image, index| %>
                <button type="button" 
                        class="thumbnail-btn aspect-square border-2 transition-all <%= index == 0 ? 'border-slate-900 shadow-lg' : 'border-slate-100 grayscale hover:grayscale-0' %>"
                        onclick="changeMainImage(this, '<%= url_for(image) %>')">
                  <%= image_tag image, class: "w-full h-full object-cover" %>
                </button>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Right: Product Information -->
      <div class="lg:col-span-7 space-y-16">
        <div>
          <div class="inline-block bg-orange-600 text-white text-[10px] font-black uppercase tracking-[0.3em] px-4 py-2 mb-8">
            <%= @product.category&.name || "Industrial Protection" %>
          </div>
          
          <h1 class="text-4xl md:text-6xl font-black text-slate-900 tracking-tighter leading-none uppercase mb-8">
            <%= @product.name %>
          </h1>
          
          <div class="flex items-center space-x-6">
              <div id="price-display" class="text-5xl font-black text-slate-900 tracking-tighter">
                <span class="text-xl font-bold text-orange-600 mr-1">$</span>
                <span>
                  <%= number_to_currency(@product.min_price, unit: "", precision: 2) %>
                </span>
              <% if @product.variants.active.any? && @product.min_price != @product.max_price %>
                <span class="text-slate-200 text-2xl mx-2">—</span>
                <span class="text-slate-300 text-3xl font-bold">$<%= number_to_currency(@product.max_price, unit: "", precision: 2) %></span>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Summary -->
        <% if @product.summary.present? %>
          <div class="border-l-4 border-orange-600 pl-8 italic">
            <p class="text-lg text-slate-500 font-bold leading-relaxed">
              <%= @product.summary %>
            </p>
          </div>
        <% end %>

        <!-- Actions -->
        <div class="space-y-12">
          <%= form_with url: add_to_cart_product_path(@product), method: :post, class: "space-y-12" do |f| %>
            <% if @product.variants.active.any? %>
              <div>
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-6">Select Specification</label>
                <div class="grid grid-cols-1 gap-3">
                  <% @product.variants.active.ordered.each_with_index do |variant, index| %>
                    <label class="relative group cursor-pointer block">
                      <input type="radio" name="variant_id" value="<%= variant.id %>" class="sr-only peer" <%= 'checked' if index == 0 %>>
                      <div class="p-5 border-2 border-slate-100 peer-checked:border-slate-900 peer-checked:bg-slate-50 transition-all flex justify-between items-center group-hover:border-slate-300">
                        <div class="flex items-center space-x-4">
                          <div class="w-1.5 h-1.5 rounded-full bg-slate-200 peer-checked:bg-orange-500"></div>
                          <span class="text-sm font-black text-slate-900 uppercase tracking-tight"><%= variant.title %></span>
                        </div>
                        <span class="text-sm font-black text-slate-900">$<%= number_to_currency(variant.price, unit: "", precision: 2) %></span>
                      </div>
                    </label>
                  <% end %>
                </div>
              </div>
              
              <div class="pt-6">
                <%= f.button class: "w-full py-6 bg-orange-600 text-white font-black text-xs uppercase tracking-[0.3em] hover:bg-orange-700 transition-all active:scale-[0.98] shadow-xl shadow-orange-900/20" do %>
                  Add to Procurement List
                <% end %>
                <div class="flex justify-center space-x-10 mt-8">
                  <div class="flex items-center space-x-2 opacity-40">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.9L10 9.503l7.834-4.603L10 1.01 2.166 4.9zM10 11.03l7.834-4.603V15.1a1 1 0 01-.502.865l-6.832 4.02a1 1 0 01-.996 0l-6.832-4.02A1 1 0 012 15.1V6.427l8 4.603z" clip-rule="evenodd"/></svg>
                    <span class="text-[9px] font-black uppercase tracking-widest">Global Export</span>
                  </div>
                  <div class="flex items-center space-x-2 opacity-40">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"/></svg>
                    <span class="text-[9px] font-black uppercase tracking-widest">Compliance Ready</span>
                  </div>
                </div>
              </div>
            <% else %>
              <div class="p-10 bg-slate-50 border border-slate-100 text-center">
                <span class="text-[10px] font-black uppercase tracking-widest text-slate-400">Inventory Under Review</span>
                <p class="text-xs mt-2 font-bold uppercase tracking-tight">Contact us for availability</p>
                <%= link_to "Inquiry Now", contact_us_path, class: "mt-6 inline-block text-xs font-black uppercase tracking-widest border-b-2 border-slate-900 pb-1" %>
              </div>
            <% end %>
          <% end %>
        </div>

        <!-- Description -->
        <div class="pt-16 border-t border-slate-100 space-y-8">
          <div>
            <h3 class="text-xs font-black uppercase tracking-[0.3em] text-slate-900 mb-6">Technical Specifications</h3>
            <div class="text-slate-500 font-bold text-sm leading-relaxed whitespace-pre-wrap tracking-wide">
              <%= @product.description.presence || "No technical description provided." %>
            </div>
          </div>
          
          <div class="grid grid-cols-2 gap-8 text-[10px] font-black uppercase tracking-widest text-slate-300">
            <div>
              <span class="block mb-1">Stock ID</span>
              <span class="text-slate-900">OT-PRD-<%= @product.id.to_s.rjust(4, '0') %></span>
            </div>
            <div>
              <span class="block mb-1">Update Status</span>
              <span class="text-slate-900"><%= @product.updated_at.strftime("%Y / %m / %d") %></span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Related Products -->
    <div class="mt-48 pt-20 border-t border-slate-100">
      <div class="flex items-end justify-between mb-20">
        <div>
          <h2 class="text-orange-600 font-black text-xs uppercase tracking-[0.3em] mb-4">Related Gear</h2>
          <h3 class="text-4xl font-black text-slate-900 tracking-tighter uppercase leading-none">
            Matched Solutions
          </h3>
        </div>
        <%= link_to "View All →", products_path, class: "text-slate-900 font-black text-xs uppercase tracking-widest border-b-4 border-slate-900 pb-2 hover:text-orange-600 hover:border-orange-600" %>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-12">
        <% Product.visible.where.not(id: @product.id).limit(4).each do |rp| %>
          <%= link_to product_path(rp), class: "group" do %>
            <div class="aspect-square bg-slate-50 border border-slate-100 overflow-hidden mb-6 relative">
              <% if rp.images.attached? %>
                <%= image_tag rp.images.first, class: "w-full h-full object-cover grayscale-[0.5] group-hover:grayscale-0 transition-all duration-700" %>
              <% end %>
              <div class="absolute bottom-4 left-4 bg-slate-900 text-white text-[9px] font-black px-3 py-1.5 uppercase">$<%= number_to_currency(rp.min_price, unit: "", precision: 0) %></div>
            </div>
            <h4 class="font-black text-slate-900 uppercase tracking-tight group-hover:text-orange-600 transition-colors truncate mb-1"><%= rp.name %></h4>
            <span class="text-[9px] font-black uppercase tracking-widest text-slate-400"><%= rp.category&.name %></span>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  function changeMainImage(btn, src) {
    const mainImg = document.getElementById('main-product-image');
    if (mainImg) {
      mainImg.src = src;
    }
    document.querySelectorAll('.thumbnail-btn').forEach(el => el.classList.remove('border-slate-900', 'shadow-lg'));
    btn.classList.add('border-slate-900', 'shadow-lg');
  }
</script>
