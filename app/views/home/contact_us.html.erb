  <div class="bg-white min-h-[70vh] pt-32 pb-32">
    <div class="container mx-auto px-6 lg:px-12 text-center">
      <div class="inline-block bg-slate-900 text-white text-[10px] font-black uppercase tracking-[0.3em] px-6 py-3 mb-10">
        Inquiry & Support
      </div>
      <h1 class="text-6xl md:text-8xl font-black text-slate-900 tracking-tighter leading-none uppercase mb-12">
        Contact Us
      </h1>
      <p class="text-xl text-slate-500 max-w-2xl mx-auto font-bold mb-20 leading-relaxed uppercase tracking-wide">
        US CHINA OCEAN INTERNATIONAL TRADE INC. safeguards your project safety. For any questions or bulk procurement needs, please contact our experts.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 text-left">
        <div class="p-10 border border-slate-100 bg-slate-50">
          <h4 class="text-xs font-black uppercase tracking-[0.2em] mb-6 text-orange-600">Email Address</h4>
          <p class="text-lg font-black text-slate-900 truncate">support@oceantrade.com</p>
        </div>
        <div class="p-10 border border-slate-100 bg-slate-50">
          <h4 class="text-xs font-black uppercase tracking-[0.2em] mb-6 text-orange-600">Business Hours</h4>
          <p class="text-lg font-black text-slate-900 uppercase">Mon-Fri / 9AM-6PM</p>
        </div>
        <div class="p-10 border border-slate-100 bg-slate-50">
          <h4 class="text-xs font-black uppercase tracking-[0.2em] mb-6 text-orange-600">Our HQ</h4>
          <p class="text-lg font-black text-slate-900 uppercase leading-tight">US CHINA OCEAN INTERNATIONAL</p>
        </div>
      </div>

      <div class="mt-32 max-w-3xl mx-auto">
        <div class="bg-white p-12 border-4 border-slate-900">
          <h2 class="text-3xl font-black text-slate-900 uppercase tracking-tighter mb-10 text-center underline decoration-orange-500 decoration-8 underline-offset-8">Send Procurement Inquiry</h2>
          <%= form_with model: @inquiry, url: contact_us_path, class: "space-y-8" do |f| %>
            <% if @inquiry.errors.any? %>
              <div class="bg-red-600 text-white p-6 text-xs font-black uppercase tracking-widest">
                <% @inquiry.errors.full_messages.each do |msg| %>
                  <div><%= msg %></div>
                <% end %>
              </div>
            <% end %>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div>
                <%= f.label :name, "Full Name", class: "block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2" %>
                <%= f.text_field :name, class: "w-full bg-slate-50 border-2 border-slate-100 p-4 text-sm font-bold focus:border-slate-900 outline-none transition-all" %>
              </div>
              <div>
                <%= f.label :email, "Email Address", class: "block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2" %>
                <%= f.email_field :email, class: "w-full bg-slate-50 border-2 border-slate-100 p-4 text-sm font-bold focus:border-slate-900 outline-none transition-all" %>
              </div>
            </div>

            <div>
              <%= f.label :subject, "Procurement Subject", class: "block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2" %>
              <%= f.select :subject, ["Order Inquiry", "Product Question", "Wholesale Inquiry", "Other"], { prompt: "Select a topic" }, class: "w-full bg-slate-50 border-2 border-slate-100 p-4 text-sm font-bold focus:border-slate-900 outline-none transition-all appearance-none rounded-none" %>
            </div>

            <div>
              <%= f.label :message, "Detailed Message", class: "block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2" %>
              <%= f.text_area :message, rows: 6, class: "w-full bg-slate-50 border-2 border-slate-100 p-4 text-sm font-bold focus:border-slate-900 outline-none transition-all resize-none" %>
            </div>

            <%= f.submit "Submit Procurement Request", class: "w-full py-6 bg-slate-900 text-white font-black text-xs uppercase tracking-[0.3em] hover:bg-orange-600 transition-all cursor-pointer" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
