  <!-- Contact Section -->
  <section class="py-24 bg-gradient-to-br from-slate-50 via-white to-orange-50 relative overflow-hidden">
    <!-- Background Decoration -->
    <div class="absolute inset-0 opacity-30">
      <div class="absolute top-20 left-10 w-72 h-72 bg-orange-200 rounded-full mix-blend-multiply filter blur-3xl"></div>
      <div class="absolute bottom-20 right-10 w-72 h-72 bg-blue-200 rounded-full mix-blend-multiply filter blur-3xl"></div>
    </div>
    
    <div class="container mx-auto px-6 lg:px-12 relative z-10">
      <!-- Header -->
      <div class="text-center max-w-4xl mx-auto mb-16">
        <div class="inline-flex items-center space-x-2 bg-orange-100 text-orange-700 px-6 py-2.5 rounded-full mb-8">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
            <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
          </svg>
          <span class="text-xs font-bold uppercase tracking-wider">Get In Touch</span>
        </div>
        <h1 class="text-5xl md:text-6xl font-black text-slate-900 tracking-tight mb-6">
          Contact <span class="text-orange-600">Our Team</span>
        </h1>
        <p class="text-xl text-slate-600 max-w-2xl mx-auto font-medium leading-relaxed">
          Have questions about our safety equipment? Need a custom quote? Our experts are here to help you find the perfect solution.
        </p>
      </div>

      <!-- Contact Info Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
        <!-- Email Card -->
        <div class="group bg-white p-8 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 border border-slate-100 hover:border-orange-500">
          <div class="w-14 h-14 bg-gradient-to-br from-orange-500 to-orange-600 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300 shadow-lg shadow-orange-500/30">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-black text-slate-900 mb-3">Email Us</h3>
          <a href="mailto:oceantrade327@gmail.com" class="text-orange-600 font-bold hover:text-orange-700 transition-colors break-all">
            oceantrade327@gmail.com
          </a>
          <p class="text-sm text-slate-500 font-medium mt-2">Response within 24 hours</p>
        </div>
        
        <!-- Phone Card -->
        <div class="group bg-white p-8 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 border border-slate-100 hover:border-orange-500">
          <div class="w-14 h-14 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300 shadow-lg shadow-blue-500/30">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-black text-slate-900 mb-3">Call Us</h3>
          <a href="tel:6265005507" class="text-orange-600 font-bold hover:text-orange-700 transition-colors">
            (626) 500-5507
          </a>
          <p class="text-sm text-slate-500 font-medium mt-2">Mon-Fri, 9AM-6PM PST</p>
        </div>
        
        <!-- Location Card -->
        <div class="group bg-white p-8 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 border border-slate-100 hover:border-orange-500">
          <div class="w-14 h-14 bg-gradient-to-br from-green-500 to-green-600 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300 shadow-lg shadow-green-500/30">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-black text-slate-900 mb-3">Visit Us</h3>
          <p class="text-slate-600 font-bold leading-relaxed">
            US CHINA OCEAN<br>INTERNATIONAL TRADE INC
          </p>
          <p class="text-sm text-slate-500 font-medium mt-2">California, USA</p>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-3xl shadow-2xl overflow-hidden">
          <!-- Form Header -->
          <div class="bg-gradient-to-r from-slate-900 to-slate-800 p-10 text-center">
            <h2 class="text-3xl font-black text-white mb-3">Send Us a Message</h2>
            <p class="text-slate-300 font-medium">Fill out the form below and we'll get back to you promptly</p>
          </div>
          
          <!-- Form Body -->
          <div class="p-10">
            <%= form_with model: @inquiry, url: contact_us_path, class: "space-y-8" do |f| %>
              <% if @inquiry.errors.any? %>
                <div class="bg-red-50 border-l-4 border-red-500 p-6 rounded-lg">
                  <div class="flex items-start">
                    <svg class="w-6 h-6 text-red-500 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <div>
                      <h4 class="text-red-800 font-bold mb-2">Please correct the following errors:</h4>
                      <ul class="text-red-700 text-sm space-y-1">
                        <% @inquiry.errors.full_messages.each do |msg| %>
                          <li>• <%= msg %></li>
                        <% end %>
                      </ul>
                    </div>
                  </div>
                </div>
              <% end %>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <%= f.label :name, "Full Name *", class: "block text-sm font-bold text-slate-700 mb-2" %>
                  <%= f.text_field :name, class: "w-full px-4 py-4 bg-slate-50 border-2 border-slate-200 rounded-lg text-slate-900 font-medium focus:border-orange-500 focus:ring-4 focus:ring-orange-500/10 transition-all outline-none", placeholder: "John Doe" %>
                </div>
                
                <div>
                  <%= f.label :email, "Email Address *", class: "block text-sm font-bold text-slate-700 mb-2" %>
                  <%= f.email_field :email, class: "w-full px-4 py-4 bg-slate-50 border-2 border-slate-200 rounded-lg text-slate-900 font-medium focus:border-orange-500 focus:ring-4 focus:ring-orange-500/10 transition-all outline-none", placeholder: "john@company.com" %>
                </div>
              </div>

              <div>
                <%= f.label :subject, "Subject *", class: "block text-sm font-bold text-slate-700 mb-2" %>
                <%= f.select :subject, ["Order Inquiry", "Product Question", "Wholesale Inquiry", "Partnership Opportunity", "Other"], { prompt: "Select a subject" }, class: "w-full px-4 py-4 bg-slate-50 border-2 border-slate-200 rounded-lg text-slate-900 font-medium focus:border-orange-500 focus:ring-4 focus:ring-orange-500/10 transition-all outline-none appearance-none cursor-pointer" %>
              </div>

              <div>
                <%= f.label :message, "Message *", class: "block text-sm font-bold text-slate-700 mb-2" %>
                <%= f.text_area :message, rows: 6, class: "w-full px-4 py-4 bg-slate-50 border-2 border-slate-200 rounded-lg text-slate-900 font-medium focus:border-orange-500 focus:ring-4 focus:ring-orange-500/10 transition-all outline-none resize-none", placeholder: "Tell us about your requirements..." %>
              </div>

              <%= f.submit "Send Message", class: "w-full py-5 bg-gradient-to-r from-orange-600 to-orange-500 text-white font-bold rounded-lg uppercase tracking-wide hover:shadow-xl hover:shadow-orange-500/30 hover:-translate-y-1 transition-all duration-300 cursor-pointer" %>
            <% end %>
            
            <p class="text-center text-sm text-slate-500 font-medium mt-6">
              By submitting this form, you agree to our privacy policy. We'll never share your information with third parties.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
