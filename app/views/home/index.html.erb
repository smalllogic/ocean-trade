<!-- Hero Carousel Section -->
<div class="relative w-full h-[600px] overflow-hidden bg-gray-900" data-controller="carousel">
  <!-- Carousel Slides -->
  <div class="relative h-full">
    <!-- Slide 1 -->
    <div class="carousel-slide absolute inset-0 transition-opacity duration-1000 opacity-100" data-carousel-target="slide">
      <%= image_tag "banner1.jpg", class: "w-full h-full object-cover", alt: "Banner 1" %>
      <div class="absolute inset-0 bg-black/30">
        <div class="w-full h-full flex items-center px-6">
          <div class="max-w-2xl text-white">
            <h1 class="text-6xl font-bold mb-6 leading-tight drop-shadow-lg">Discover Your Style</h1>
            <p class="text-xl mb-8 text-white/90 drop-shadow">Elevate your wardrobe with our curated collection of premium fashion pieces</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Slide 2 -->
    <div class="carousel-slide absolute inset-0 transition-opacity duration-1000 opacity-0" data-carousel-target="slide">
      <%= image_tag "banner2.jpg", class: "w-full h-full object-cover", alt: "Banner 2" %>
      <div class="absolute inset-0 bg-black/30">
        <div class="w-full h-full flex items-center px-6">
          <div class="max-w-2xl text-white">
            <h1 class="text-6xl font-bold mb-6 leading-tight drop-shadow-lg">New Arrivals</h1>
            <p class="text-xl mb-8 text-white/90 drop-shadow">Fresh styles just landed. Be the first to explore our latest collection</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Slide 3 -->
    <div class="carousel-slide absolute inset-0 transition-opacity duration-1000 opacity-0" data-carousel-target="slide">
      <%= image_tag "banner3.jpg", class: "w-full h-full object-cover", alt: "Banner 3" %>
      <div class="absolute inset-0 bg-black/30">
        <div class="w-full h-full flex items-center px-6">
          <div class="max-w-2xl text-white">
            <h1 class="text-6xl font-bold mb-6 leading-tight drop-shadow-lg">Limited Edition</h1>
            <p class="text-xl mb-8 text-white/90 drop-shadow">Exclusive pieces that make a statement. Shop before they're gone</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Navigation Arrows -->
  <button data-action="click->carousel#previous" class="absolute left-6 top-1/2 -translate-y-1/2 bg-white/20 hover:bg-white/40 backdrop-blur-sm text-white p-4 rounded-full transition duration-300 z-10">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
    </svg>
  </button>
  <button data-action="click->carousel#next" class="absolute right-6 top-1/2 -translate-y-1/2 bg-white/20 hover:bg-white/40 backdrop-blur-sm text-white p-4 rounded-full transition duration-300 z-10">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
    </svg>
  </button>

  <!-- Indicators -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex space-x-3 z-10">
    <button data-action="click->carousel#goToSlide" data-slide-index="0" class="carousel-indicator w-3 h-3 rounded-full bg-white transition duration-300"></button>
    <button data-action="click->carousel#goToSlide" data-slide-index="1" class="carousel-indicator w-3 h-3 rounded-full bg-white/50 transition duration-300"></button>
    <button data-action="click->carousel#goToSlide" data-slide-index="2" class="carousel-indicator w-3 h-3 rounded-full bg-white/50 transition duration-300"></button>
  </div>
</div>

<!-- Features Section -->
<section class="py-20 bg-white">
  <div class="w-full px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div class="text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-indigo-100 rounded-full mb-6">
          <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Free Shipping</h3>
        <p class="text-gray-600">On all orders over $50. Fast and reliable delivery worldwide</p>
      </div>
      <div class="text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-rose-100 rounded-full mb-6">
          <svg class="w-8 h-8 text-rose-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Secure Payment</h3>
        <p class="text-gray-600">Your payment information is processed securely</p>
      </div>
      <div class="text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-emerald-100 rounded-full mb-6">
          <svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Easy Returns</h3>
        <p class="text-gray-600">30-day return policy. No questions asked</p>
      </div>
    </div>
  </div>
</section>

<!-- Categories Section -->
<section class="py-20 bg-gray-50">
  <div class="w-full px-6">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900 mb-4">Shop by Category</h2>
      <p class="text-xl text-gray-600">Find exactly what you're looking for</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <%= link_to products_path, class: "group relative overflow-hidden rounded-2xl h-80 bg-gradient-to-br from-purple-400 to-pink-400 hover:shadow-2xl transition duration-300 transform hover:scale-105" do %>
        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/30 transition duration-300"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <h3 class="text-3xl font-bold text-white">Women's</h3>
        </div>
      <% end %>
      
      <%= link_to products_path, class: "group relative overflow-hidden rounded-2xl h-80 bg-gradient-to-br from-blue-400 to-cyan-400 hover:shadow-2xl transition duration-300 transform hover:scale-105" do %>
        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/30 transition duration-300"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <h3 class="text-3xl font-bold text-white">Men's</h3>
        </div>
      <% end %>
      
      <%= link_to products_path, class: "group relative overflow-hidden rounded-2xl h-80 bg-gradient-to-br from-orange-400 to-red-400 hover:shadow-2xl transition duration-300 transform hover:scale-105" do %>
        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/30 transition duration-300"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <h3 class="text-3xl font-bold text-white">Accessories</h3>
        </div>
      <% end %>
      
      <%= link_to products_path, class: "group relative overflow-hidden rounded-2xl h-80 bg-gradient-to-br from-green-400 to-teal-400 hover:shadow-2xl transition duration-300 transform hover:scale-105" do %>
        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/30 transition duration-300"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <h3 class="text-3xl font-bold text-white">Sale</h3>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- CTA Section -->
<section class="py-20 bg-gradient-to-r from-indigo-600 to-purple-600">
  <div class="w-full px-6 text-center">
    <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">Join Our Newsletter</h2>
    <p class="text-xl text-indigo-100 mb-10 max-w-2xl mx-auto">Get exclusive access to new arrivals, special offers, and style tips</p>
    <div class="max-w-md mx-auto flex gap-4">
      <input type="email" placeholder="Enter your email" class="flex-1 px-6 py-4 rounded-full text-gray-900 focus:outline-none focus:ring-4 focus:ring-white/50">
      <button class="bg-white text-indigo-600 font-bold px-8 py-4 rounded-full hover:bg-indigo-50 transition duration-300 shadow-lg">Subscribe</button>
    </div>
  </div>
</section>
