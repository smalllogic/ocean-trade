<!-- Hero Section -->
<section class="relative min-h-[85vh] flex items-center bg-white overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-gradient-to-r from-white via-white/90 to-white/40 z-10"></div>
    <% if Rails.application.assets.resolver.resolve("banner1.png") %>
      <%= image_tag "banner1.png", class: "w-full h-full object-cover opacity-20", alt: "Safety Equipment Banner" %>
    <% else %>
      <div class="w-full h-full bg-slate-50 flex items-center justify-center">
        <div class="text-slate-900/5 font-black text-[20vw] select-none uppercase tracking-tighter">SAFETY</div>
      </div>
    <% end %>
  </div>

  <div class="container mx-auto px-6 lg:px-12 relative z-20 pt-20">
    <div class="max-w-4xl">
      <div class="inline-flex items-center space-x-3 bg-orange-600/10 border border-orange-500/20 px-4 py-2 rounded-full mb-8">
        <span class="flex h-2 w-2 rounded-full bg-orange-500 animate-pulse"></span>
        <span class="text-orange-600 text-xs font-black uppercase tracking-[0.2em]">Premium Protection</span>
      </div>
      
      <h1 class="text-6xl md:text-8xl font-black text-slate-900 leading-[0.95] mb-8 tracking-tighter uppercase">
        Order and Buy<br/><span class="text-orange-600">Safety Supplies</span>
      </h1>
      
      <p class="text-lg md:text-xl text-slate-500 mb-14 leading-relaxed max-w-2xl font-medium">
        US CHINA OCEAN INTERNATIONAL TRADE INC provides top-tier safety protection for global industrial fields. Through rigorous quality control, we safeguard the life safety of every worker.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-6">
        <%= link_to products_path, class: "group relative inline-flex items-center justify-center px-10 py-5 bg-orange-600 text-white font-black rounded uppercase tracking-widest transition-all hover:bg-orange-700 shadow-xl shadow-orange-900/20" do %>
          <span>Browse Catalog</span>
          <svg class="w-5 h-5 ml-3 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        <% end %>
        <%= link_to contact_us_path, class: "inline-flex items-center justify-center px-10 py-5 border-2 border-slate-900 text-slate-900 font-black rounded uppercase tracking-widest hover:bg-slate-50 transition-all" do %>
          Consult Expert
        <% end %>
      </div>
    </div>
  </div>
  
  <!-- Side Decoration -->
  <div class="hidden lg:block absolute bottom-0 right-0 w-1/3 h-full pointer-events-none">
    <div class="absolute bottom-0 right-0 w-full h-1/2 bg-gradient-to-t from-orange-600/5 to-transparent"></div>
    <div class="absolute bottom-20 right-20 text-[12rem] font-black text-slate-900/5 leading-none uppercase select-none origin-bottom-right -rotate-90">B2B TRADE</div>
  </div>
</section>

<!-- Stats Grid -->
<section class="py-16 bg-white border-b border-slate-100">
  <div class="container mx-auto px-6">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-0">
      <div class="lg:border-r border-slate-100 px-8">
        <div class="text-4xl font-black text-slate-900 mb-2">15+</div>
        <div class="text-[10px] text-slate-500 font-bold uppercase tracking-[0.2em]">Industry Exp (Years)</div>
      </div>
      <div class="lg:border-r border-slate-100 px-8">
        <div class="text-4xl font-black text-slate-900 mb-2">500+</div>
        <div class="text-[10px] text-slate-500 font-bold uppercase tracking-[0.2em]">Certified Products</div>
      </div>
      <div class="lg:border-r border-slate-100 px-8">
        <div class="text-4xl font-black text-slate-900 mb-2">24h</div>
        <div class="text-[10px] text-slate-500 font-bold uppercase tracking-[0.2em]">Response Speed</div>
      </div>
      <div class="px-8">
        <div class="text-4xl font-black text-slate-900 mb-2">Global</div>
        <div class="text-[10px] text-slate-500 font-bold uppercase tracking-[0.2em]">International Trade Support</div>
      </div>
    </div>
  </div>
</section>

<!-- Categories Redesign -->
<section class="py-32 bg-white">
  <div class="container mx-auto px-6">
    <div class="flex flex-col lg:flex-row lg:items-end justify-between mb-20 gap-8">
      <div>
        <h2 class="text-orange-600 font-black text-xs uppercase tracking-[0.3em] mb-4">Core Collections</h2>
        <h3 class="text-5xl font-black text-slate-900 tracking-tighter uppercase leading-none">
          Core Protection<span class="text-slate-200 ml-4 italic">/ SERIES</span>
        </h3>
      </div>
      <%= link_to "View All Products →", products_path, class: "text-slate-900 font-black text-xs uppercase tracking-widest border-b-4 border-slate-900 pb-2 hover:text-orange-600 hover:border-orange-600 transition-all" %>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
      <!-- 劳保手套 -->
      <div class="group relative aspect-[16/10] overflow-hidden bg-white border border-slate-100 rounded-sm hover:shadow-2xl transition-all duration-500">
        <div class="absolute inset-0 bg-slate-900/10 group-hover:bg-slate-900/0 transition-all duration-700 z-10"></div>
        <% if Rails.application.assets.resolver.resolve("pic1.png") %>
          <%= image_tag "pic1.png", class: "w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-110" %>
        <% else %>
          <div class="w-full h-full flex items-center justify-center bg-slate-50">
            <span class="text-slate-200 font-black text-6xl uppercase -rotate-6">Gloves</span>
          </div>
        <% end %>
        
        <div class="absolute bottom-0 left-0 p-12 z-30 w-full bg-gradient-to-t from-slate-900/80 to-transparent">
          <div class="h-1 w-12 bg-orange-600 mb-6 transition-all group-hover:w-24"></div>
          <h4 class="text-4xl font-black text-white mb-4 uppercase tracking-tighter">Industrial Gloves</h4>
          <p class="text-slate-200 text-sm font-medium mb-8 max-w-sm opacity-0 group-hover:opacity-100 transition-opacity duration-500">
            Top-tier protection designed for cutting, chemical corrosion, and extreme temperatures.
          </p>
          <%= link_to "Order Now", products_path(category_id: Category.find_by(name: "Safety Gloves")&.id), class: "inline-block text-white font-black text-xs uppercase tracking-widest border-2 border-white/50 px-8 py-4 hover:bg-orange-600 hover:border-orange-600 transition-all" %>
        </div>
      </div>

      <!-- 劳保鞋 -->
      <div class="group relative aspect-[16/10] overflow-hidden bg-white border border-slate-100 rounded-sm hover:shadow-2xl transition-all duration-500">
        <div class="absolute inset-0 bg-slate-900/10 group-hover:bg-slate-900/0 transition-all duration-700 z-10"></div>
        <% if Rails.application.assets.resolver.resolve("pic3.png") %>
          <%= image_tag "pic3.png", class: "w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-110" %>
        <% else %>
          <div class="w-full h-full flex items-center justify-center bg-slate-50">
            <span class="text-slate-200 font-black text-6xl uppercase rotate-6">Shoes</span>
          </div>
        <% end %>

        <div class="absolute bottom-0 left-0 p-12 z-30 w-full bg-gradient-to-t from-slate-900/80 to-transparent">
          <div class="h-1 w-12 bg-orange-600 mb-6 transition-all group-hover:w-24"></div>
          <h4 class="text-4xl font-black text-white mb-4 uppercase tracking-tighter">Safety Shoes</h4>
          <p class="text-slate-200 text-sm font-medium mb-8 max-w-sm opacity-0 group-hover:opacity-100 transition-opacity duration-500">
            Steel-toed, anti-piercing soles providing solid support for various complex working conditions.
          </p>
          <%= link_to "Order Now", products_path(category_id: Category.find_by(name: "Safety Shoes")&.id), class: "inline-block text-white font-black text-xs uppercase tracking-widest border-2 border-white/50 px-8 py-4 hover:bg-orange-600 hover:border-orange-600 transition-all" %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Why Choose Us -->
<section class="py-32 bg-slate-50 relative">
  <div class="container mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-20">
      <div class="lg:col-span-1">
        <h2 class="text-orange-600 font-black text-xs uppercase tracking-[0.3em] mb-6">Our Edge</h2>
        <h3 class="text-5xl font-black text-slate-900 tracking-tighter uppercase mb-10 leading-none">
          Why Choose<br/>OCEAN TRADE?
        </h3>
        <p class="text-slate-500 font-medium leading-relaxed">
          As cross-border trade experts, we integrate premium supply chain resources to ensure every product meets the highest international safety certifications.
        </p>
      </div>
      
      <div class="lg:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="p-10 bg-white border-t-8 border-slate-900 shadow-sm">
          <div class="w-12 h-12 bg-slate-900 text-white flex items-center justify-center mb-8">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
          </div>
          <h4 class="text-xl font-black text-slate-900 mb-4 uppercase tracking-tight">Global Standards</h4>
          <p class="text-sm text-slate-500 font-medium leading-relaxed">Strictly implement international safety standards such as CE and ANSI. Each batch is tested by independent laboratories to ensure 100% compliance of protection performance.</p>
        </div>

        <div class="p-10 bg-white border-t-8 border-orange-600 shadow-sm">
          <div class="w-12 h-12 bg-orange-600 text-white flex items-center justify-center mb-8">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          </div>
          <h4 class="text-xl font-black text-slate-900 mb-4 uppercase tracking-tight">Flexible Supply Chain</h4>
          <p class="text-sm text-slate-500 font-medium leading-relaxed">Support bulk order customization and rapid replenishment. Relying on a strong logistics system to ensure your project progress is not affected by equipment shortages.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-32 bg-slate-900 relative">
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
  </div>
  <div class="container mx-auto px-6 relative z-10 text-center">
    <h3 class="text-4xl md:text-6xl font-black text-white mb-10 tracking-tighter uppercase">Ready to upgrade your <span class="text-orange-500">Protection</span>?</h3>
    <p class="text-slate-400 text-lg mb-16 max-w-2xl mx-auto font-medium">Our team of experts is ready to provide you with customized safety solutions and highly competitive quotes.</p>
    <%= link_to "Get Quote Now →", contact_us_path, class: "inline-block px-14 py-6 bg-white text-slate-900 font-black rounded-none uppercase tracking-[0.2em] transition-all hover:bg-orange-600 hover:text-white" %>
  </div>
</section>