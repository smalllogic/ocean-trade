<div class="w-full">
  <div class="text-center py-20">
    <h1 class="text-5xl font-bold text-gray-900 mb-4">
      欢迎来到 Fandisha
    </h1>
    <p class="text-xl text-gray-600 mb-8">
      Rails 8 + Tailwind CSS + Devise 已配置完成
    </p>
    
    <div class="space-x-4">
      <% if user_signed_in? %>
        <%= link_to "退出登录", destroy_user_session_path, data: { turbo_method: :delete }, 
            class: "inline-block bg-red-500 hover:bg-red-600 text-white font-bold py-3 px-6 rounded-lg transition" %>
      <% else %>
        <%= link_to "登录", new_user_session_path, 
            class: "inline-block bg-blue-500 hover:bg-blue-600 text-white font-bold py-3 px-6 rounded-lg transition" %>
        <%= link_to "注册", new_user_registration_path, 
            class: "inline-block bg-green-500 hover:bg-green-600 text-white font-bold py-3 px-6 rounded-lg transition" %>
      <% end %>
    </div>

    <div class="mt-12 p-6 bg-gray-100 rounded-lg inline-block">
      <h2 class="text-2xl font-semibold mb-4">已安装的 Gems：</h2>
      <ul class="text-left space-y-2">
        <li>✅ <strong>Devise</strong> - 用户认证系统</li>
        <li>✅ <strong>Simple Form</strong> - 表单助手</li>
        <li>✅ <strong>Pagy</strong> - 分页工具</li>
        <li>✅ <strong>Heroicon</strong> - 图标库</li>
        <li>✅ <strong>Tailwind CSS</strong> - CSS 框架</li>
      </ul>
    </div>
  </div>
</div>
