<div class="w-full max-w-5xl mx-auto px-6 py-16">
  <div class="bg-white shadow-xl rounded-2xl overflow-hidden border border-gray-100">
    <div class="bg-gray-900 px-8 py-12 text-center relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-indigo-900/20 to-emerald-900/20 pointer-events-none"></div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white relative z-10 tracking-tight">Help Center</h1>
      <p class="mt-4 text-white/70 relative z-10 max-w-2xl mx-auto italic font-light">Find answers to frequently asked questions and learn more about our luxury products.</p>
      <div class="mt-6 h-1 w-24 bg-emerald-500 mx-auto rounded-full relative z-10"></div>
    </div>

    <div class="p-8 md:p-12 space-y-12">
      <!-- Search Placeholder -->
      <div class="max-w-2xl mx-auto relative reveal">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </div>
        <input type="text" placeholder="Search for help..." class="block w-full pl-10 pr-3 py-4 border border-gray-200 rounded-2xl leading-5 bg-stone-50 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition duration-300">
      </div>

      <!-- FAQ Sections -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Order & Shipping -->
        <section class="reveal">
          <h2 class="text-xl font-bold text-gray-900 mb-6 flex items-center">
            <span class="w-10 h-10 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center mr-3">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path>
              </svg>
            </span>
            Ordering & Shipping
          </h2>
          <div class="space-y-4">
            <div class="p-5 bg-stone-50 rounded-xl hover:shadow-md transition cursor-pointer group">
              <h3 class="font-bold text-gray-900 group-hover:text-emerald-600 transition">How long does shipping take?</h3>
              <p class="mt-2 text-sm text-gray-600 leading-relaxed">Processing typically takes 1-3 business days. Domestic shipping takes 3-5 days, while international shipping varies by location.</p>
            </div>
            <div class="p-5 bg-stone-50 rounded-xl hover:shadow-md transition cursor-pointer group">
              <h3 class="font-bold text-gray-900 group-hover:text-emerald-600 transition">Can I track my order?</h3>
              <p class="mt-2 text-sm text-gray-600 leading-relaxed">Yes! Once your order has shipped, you will receive a tracking number via email to monitor your luxury bundles.</p>
            </div>
          </div>
        </section>

        <!-- Product Care -->
        <section class="reveal reveal-delay-2">
          <h2 class="text-xl font-bold text-gray-900 mb-6 flex items-center">
            <span class="w-10 h-10 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center mr-3">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </span>
            Hair Care & Quality
          </h2>
          <div class="space-y-4">
            <div class="p-5 bg-stone-50 rounded-xl hover:shadow-md transition cursor-pointer group">
              <h3 class="font-bold text-gray-900 group-hover:text-emerald-600 transition">How should I maintain my bundles?</h3>
              <p class="mt-2 text-sm text-gray-600 leading-relaxed">We recommend using sulfate-free products, regular deep conditioning, and avoiding excessive heat to preserve the natural lustre.</p>
            </div>
            <div class="p-5 bg-stone-50 rounded-xl hover:shadow-md transition cursor-pointer group">
              <h3 class="font-bold text-gray-900 group-hover:text-emerald-600 transition">Are these 100% human hair?</h3>
              <p class="mt-2 text-sm text-gray-600 leading-relaxed">Absolutely. We only source 100% premium human hair that is thick from root to tip for a flawless finish.</p>
            </div>
          </div>
        </section>

        <!-- Payments -->
        <section class="reveal">
          <h2 class="text-xl font-bold text-gray-900 mb-6 flex items-center">
            <span class="w-10 h-10 bg-amber-50 text-amber-600 rounded-xl flex items-center justify-center mr-3">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </span>
            Payments & Security
          </h2>
          <div class="space-y-4">
            <div class="p-5 bg-stone-50 rounded-xl hover:shadow-md transition cursor-pointer group">
              <h3 class="font-bold text-gray-900 group-hover:text-emerald-600 transition">What payment methods do you accept?</h3>
              <p class="mt-2 text-sm text-gray-600 leading-relaxed">We accept all major credit cards and secure online payment gateways for your peace of mind.</p>
            </div>
          </div>
        </section>

        <!-- Policies -->
        <section class="reveal reveal-delay-2">
          <h2 class="text-xl font-bold text-gray-900 mb-6 flex items-center">
            <span class="w-10 h-10 bg-purple-50 text-purple-600 rounded-xl flex items-center justify-center mr-3">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
            </span>
            Our Policies
          </h2>
          <div class="space-y-4">
            <div class="p-5 bg-stone-50 rounded-xl hover:shadow-md transition cursor-pointer group">
              <h3 class="font-bold text-gray-900 group-hover:text-emerald-600 transition">View Refund & Exchange Policy</h3>
              <p class="mt-2 text-sm text-gray-600 leading-relaxed">Due to hygienic reasons, all sales are final. Learn more about our exchange eligibility on our policy page.</p>
              <%= link_to "Read Full Policy →", refund_policy_path, class: "mt-3 inline-block text-emerald-600 font-bold text-xs" %>
            </div>
          </div>
        </section>
      </div>

      <!-- Still Need Help? -->
      <section class="reveal bg-gray-900 rounded-[2rem] p-10 text-center relative overflow-hidden">
        <div class="absolute inset-0 bg-emerald-500/10 pointer-events-none"></div>
        <h2 class="text-3xl font-bold text-white mb-4 relative z-10">Still have questions?</h2>
        <p class="text-white/70 mb-8 relative z-10 font-light">Our dedicated team is here to assist you with any inquiries.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-4 relative z-10">
          <%= link_to "Contact Us", contact_us_path, class: "px-10 py-4 bg-emerald-500 text-white font-bold rounded-full hover:bg-emerald-600 transition shadow-xl" %>
          <a href="mailto:support@fandisha.com" class="px-10 py-4 bg-white/10 text-white font-bold rounded-full hover:bg-white/20 transition backdrop-blur-sm">Email Support</a>
        </div>
      </section>
    </div>

    <div class="bg-gray-50 px-8 py-6 text-center border-t border-gray-100">
      <%= link_to root_path, class: "text-gray-500 hover:text-gray-900 font-bold transition flex items-center justify-center group" do %>
        <svg class="w-4 h-4 mr-2 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Home
      <% end %>
    </div>
  </div>
</div>

<style>
  .reveal { opacity: 0; transform: translateY(20px); transition: all 0.8s ease-out; }
  .reveal.revealed { opacity: 1; transform: translateY(0); }
  .reveal-delay-2 { transition-delay: 150ms; }
</style>

<script>
  (function(){
    let io = null;
    function init(){
      const reveals = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window){
        io = new IntersectionObserver((entries)=>{
          entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('revealed'); io.unobserve(e.target); } });
        }, { threshold: 0.1 });
        reveals.forEach(el=> io.observe(el));
      } else {
        reveals.forEach(el=> el.classList.add('revealed'));
      }
    }
    function cleanup(){
      if (io){ io.disconnect(); io = null; }
      document.querySelectorAll('.reveal').forEach(el=> el.classList.add('revealed'));
    }
    document.addEventListener('turbo:load', init);
    document.addEventListener('turbo:render', init);
    document.addEventListener('turbo:before-cache', cleanup);
  })();
</script>
