<div class="w-full max-w-4xl mx-auto px-6 py-16">
  <div class="bg-white shadow-xl rounded-2xl overflow-hidden border border-gray-100">
    <div class="bg-gray-900 px-8 py-12 text-center relative overflow-hidden">
      <!-- Background pattern/gradient -->
      <div class="absolute inset-0 bg-gradient-to-br from-emerald-900/20 to-indigo-900/20 pointer-events-none"></div>
      
      <h1 class="text-4xl md:text-5xl font-extrabold text-white relative z-10 tracking-tight">
        Refund & Exchange Policy
      </h1>
      <div class="mt-4 h-1 w-24 bg-emerald-500 mx-auto rounded-full relative z-10"></div>
    </div>

    <div class="p-8 md:p-12 space-y-12">
      <!-- Quality Promise -->
      <section class="reveal">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center">
          <span class="w-8 h-8 bg-emerald-100 text-emerald-600 rounded-lg flex items-center justify-center mr-3">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </span>
          Our Quality Promise
        </h2>
        <div class="bg-stone-50 border-l-4 border-emerald-500 p-6 rounded-r-xl">
          <p class="text-gray-700 leading-relaxed italic">
            At FANDISHA’S BUNDLES, every bundle is carefully inspected to meet our luxury standards. Due to the hygienic nature of our products, all sales are final and we do not offer refunds.
          </p>
          <p class="mt-4 text-gray-900 font-semibold">
            However, your satisfaction and confidence in our quality remain important to us.
          </p>
        </div>
      </section>

      <!-- Exchange Eligibility -->
      <section class="reveal">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center">
          <span class="w-8 h-8 bg-blue-100 text-blue-600 rounded-lg flex items-center justify-center mr-3">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>
            </svg>
          </span>
          Exchange Eligibility (Up to 3 Months)
        </h2>
        <p class="text-gray-600 mb-4">We offer an exchange only within 3 months of purchase if the hair:</p>
        <ul class="space-y-4">
          <li class="flex items-start">
            <span class="text-blue-500 mt-1 mr-3">•</span>
            <span class="text-gray-700">Becomes excessively tangled under proper care</span>
          </li>
          <li class="flex items-start">
            <span class="text-blue-500 mt-1 mr-3">•</span>
            <span class="text-gray-700">Fails to hold professional hair dye</span>
          </li>
          <li class="flex items-start">
            <span class="text-blue-500 mt-1 mr-3">•</span>
            <span class="text-gray-700">Is confirmed to have a manufacturing fault</span>
          </li>
        </ul>
        <p class="mt-6 text-sm bg-blue-50 text-blue-800 p-4 rounded-lg">
          If approved, the item will be exchanged for the same product or closest available alternative.
        </p>
      </section>

      <!-- Exchange Conditions -->
      <section class="reveal">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center">
          <span class="w-8 h-8 bg-amber-100 text-amber-600 rounded-lg flex items-center justify-center mr-3">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
            </svg>
          </span>
          Exchange Conditions
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="flex items-center p-3 bg-gray-50 rounded-lg">
            <span class="text-amber-500 mr-3">✓</span>
            <span class="text-sm text-gray-700">Hair must not be cut or chemically over-processed</span>
          </div>
          <div class="flex items-center p-3 bg-gray-50 rounded-lg">
            <span class="text-amber-500 mr-3">✓</span>
            <span class="text-sm text-gray-700">Proper hair care must have been followed</span>
          </div>
          <div class="flex items-center p-3 bg-gray-50 rounded-lg">
            <span class="text-amber-500 mr-3">✓</span>
            <span class="text-sm text-gray-700">Proof of purchase is required</span>
          </div>
          <div class="flex items-center p-3 bg-gray-50 rounded-lg">
            <span class="text-amber-500 mr-3">✓</span>
            <span class="text-sm text-gray-700">Clear photos/video evidence required</span>
          </div>
          <div class="flex items-center p-3 bg-gray-50 rounded-lg md:col-span-2">
            <span class="text-amber-500 mr-3">✓</span>
            <span class="text-sm text-gray-700">Our team must verify the issue before approval</span>
          </div>
        </div>
        <p class="mt-6 text-xs text-gray-500 italic">
          Please note: Results may vary when colouring hair. We recommend professional colouring only.
        </p>
      </section>

      <!-- Non-Refund Policy -->
      <section class="reveal">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center">
          <span class="w-8 h-8 bg-red-100 text-red-600 rounded-lg flex items-center justify-center mr-3">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </span>
          Non-Refund Policy
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div class="p-4 border border-red-100 rounded-xl text-red-800 text-sm font-medium">Refunds</div>
          <div class="p-4 border border-red-100 rounded-xl text-red-800 text-sm font-medium">Order cancellations after processing</div>
          <div class="p-4 border border-red-100 rounded-xl text-red-800 text-sm font-medium">Exchanges for change of mind</div>
          <div class="p-4 border border-red-100 rounded-xl text-red-800 text-sm font-medium">Exchanges due to improper maintenance</div>
        </div>
      </section>

      <!-- How to Request -->
      <section class="reveal bg-emerald-50 rounded-2xl p-8 border border-emerald-100">
        <h2 class="text-2xl font-bold text-emerald-900 mb-4 flex items-center">
          <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
          How to Request an Exchange
        </h2>
        <p class="text-emerald-800 mb-6">Contact us within the 3-month window:</p>
        
        <div class="space-y-4">
          <div class="flex items-center space-x-3">
            <span class="font-bold text-emerald-900">📧 Email:</span>
            <a href="mailto:support@fandisha.com" class="text-emerald-600 hover:text-emerald-700 font-bold underline transition">support@fandisha.com</a>
          </div>
          <p class="text-sm text-emerald-700 leading-relaxed">
            Include your <span class="font-bold">order number</span> and clear evidence of the issue. Our team will review and respond within <span class="font-bold">1–3 business days</span>.
          </p>
        </div>
      </section>
    </div>
    
    <div class="bg-gray-50 px-8 py-6 text-center border-t border-gray-100">
      <%= link_to products_path, class: "text-gray-600 hover:text-gray-900 font-bold transition flex items-center justify-center group" do %>
        <svg class="w-4 h-4 mr-2 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Shopping
      <% end %>
    </div>
  </div>
</div>

<style>
  .reveal { opacity: 0; transform: translateY(20px); transition: all 0.8s ease-out; }
  .reveal.revealed { opacity: 1; transform: translateY(0); }
</style>

<script>
  (function(){
    let io = null;
    function init(){
      const reveals = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window){
        io = new IntersectionObserver((entries)=>{
          entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('revealed'); io.unobserve(e.target); } });
        }, { threshold: 0.1 });
        reveals.forEach(el=> io.observe(el));
      } else {
        reveals.forEach(el=> el.classList.add('revealed'));
      }
    }
    function cleanup(){
      if (io){ io.disconnect(); io = null; }
      document.querySelectorAll('.reveal').forEach(el=> el.classList.add('revealed'));
    }
    document.addEventListener('turbo:load', init);
    document.addEventListener('turbo:render', init);
    document.addEventListener('turbo:before-cache', cleanup);
  })();
</script>