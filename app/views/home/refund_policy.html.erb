<div class="bg-gradient-to-br from-slate-50 via-white to-orange-50 min-h-screen py-24 relative overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-20">
    <div class="absolute top-20 right-20 w-96 h-96 bg-orange-200 rounded-full mix-blend-multiply filter blur-3xl"></div>
    <div class="absolute bottom-20 left-20 w-96 h-96 bg-slate-200 rounded-full mix-blend-multiply filter blur-3xl"></div>
  </div>
  
  <div class="container mx-auto px-6 lg:px-12 max-w-6xl relative z-10">
    <!-- Header -->
    <div class="text-center max-w-4xl mx-auto mb-16">
      <div class="inline-flex items-center space-x-2 bg-orange-100 text-orange-700 px-6 py-2.5 rounded-full mb-8">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
        </svg>
        <span class="text-xs font-bold uppercase tracking-wider">Our Policies</span>
      </div>
      <h1 class="text-5xl md:text-6xl font-black text-slate-900 tracking-tight mb-6">
        Refund & <span class="text-orange-600">Return</span> Policy
      </h1>
      <p class="text-xl text-slate-600 max-w-2xl mx-auto font-medium leading-relaxed">
        Clear and transparent policies to ensure your confidence in our products and services
      </p>
    </div>

    <!-- Policy Content -->
    <div class="space-y-16">
      <!-- Quality Promise Card -->
      <section class="bg-white rounded-3xl shadow-xl overflow-hidden border border-slate-100">
        <div class="bg-gradient-to-r from-slate-900 to-slate-800 p-8">
          <div class="flex items-center space-x-4">
            <div class="w-16 h-16 bg-orange-500 rounded-2xl flex items-center justify-center shadow-lg shadow-orange-500/30">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
            </div>
            <div>
              <h2 class="text-2xl font-black text-white">Quality Promise</h2>
              <p class="text-slate-300 font-medium text-sm">Our commitment to you</p>
            </div>
          </div>
        </div>
        
        <div class="p-10">
          <div class="bg-gradient-to-br from-orange-50 to-amber-50 rounded-2xl p-8 mb-8 border-2 border-orange-200">
            <p class="text-xl font-black text-slate-900 leading-tight mb-4">
              All safety product sales are considered final. In principle, no refunds will be given.
            </p>
            <p class="text-slate-600 font-medium leading-relaxed">
              US CHINA OCEAN INTERNATIONAL TRADE INC ensures every product meets industrial safety standards. Due to the special safety requirements of protective equipment, we only provide exchanges under specific quality issues.
            </p>
          </div>
        </div>
      </section>

      <!-- Two Column Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Exchange Eligibility -->
        <section class="bg-white rounded-3xl shadow-xl overflow-hidden border border-slate-100">
          <div class="bg-gradient-to-r from-orange-600 to-orange-500 p-8">
            <div class="flex items-center space-x-4">
              <div class="w-16 h-16 bg-white/20 rounded-2xl flex items-center justify-center backdrop-blur-sm">
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
                </svg>
              </div>
              <div>
                <h2 class="text-2xl font-black text-white">Exchange Eligibility</h2>
                <p class="text-orange-100 font-medium text-sm">When you can request exchange</p>
              </div>
            </div>
          </div>
          
          <div class="p-10 space-y-4">
            <div class="flex items-start space-x-4 p-5 bg-slate-50 rounded-xl border border-slate-100 hover:border-orange-500 hover:shadow-lg transition-all">
              <div class="flex-shrink-0 w-10 h-10 bg-gradient-to-br from-orange-500 to-orange-600 rounded-lg flex items-center justify-center text-white font-black text-sm">
                01
              </div>
              <div>
                <h3 class="font-bold text-slate-900 mb-1">Quality Issues</h3>
                <p class="text-sm text-slate-600 font-medium">Abnormal damage under normal usage conditions</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-4 p-5 bg-slate-50 rounded-xl border border-slate-100 hover:border-orange-500 hover:shadow-lg transition-all">
              <div class="flex-shrink-0 w-10 h-10 bg-gradient-to-br from-orange-500 to-orange-600 rounded-lg flex items-center justify-center text-white font-black text-sm">
                02
              </div>
              <div>
                <h3 class="font-bold text-slate-900 mb-1">Performance Failure</h3>
                <p class="text-sm text-slate-600 font-medium">Failure to meet promised protection levels or safety standards</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-4 p-5 bg-slate-50 rounded-xl border border-slate-100 hover:border-orange-500 hover:shadow-lg transition-all">
              <div class="flex-shrink-0 w-10 h-10 bg-gradient-to-br from-orange-500 to-orange-600 rounded-lg flex items-center justify-center text-white font-black text-sm">
                03
              </div>
              <div>
                <h3 class="font-bold text-slate-900 mb-1">Manufacturing Defects</h3>
                <p class="text-sm text-slate-600 font-medium">Confirmed manufacturing defects</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Required Conditions -->
        <section class="bg-white rounded-3xl shadow-xl overflow-hidden border border-slate-100">
          <div class="bg-gradient-to-r from-orange-600 to-orange-500 p-8">
            <div class="flex items-center space-x-4">
              <div class="w-16 h-16 bg-white/20 rounded-2xl flex items-center justify-center backdrop-blur-sm">
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <h2 class="text-2xl font-black text-white">Required Conditions</h2>
                <p class="text-orange-100 font-medium text-sm">What you need to provide</p>
              </div>
            </div>
          </div>
          
          <div class="p-10">
            <ul class="space-y-5">
              <li class="flex items-start space-x-4">
                <div class="flex-shrink-0 w-6 h-6 bg-orange-500 rounded-full flex items-center justify-center mt-0.5">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-slate-900 mb-1">Proof of Purchase</h3>
                  <p class="text-sm text-slate-600 font-medium">Provide order number or invoice</p>
                </div>
              </li>
              
              <li class="flex items-start space-x-4">
                <div class="flex-shrink-0 w-6 h-6 bg-orange-500 rounded-full flex items-center justify-center mt-0.5">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-slate-900 mb-1">Photo/Video Evidence</h3>
                  <p class="text-sm text-slate-600 font-medium">Clear documentation of the issue</p>
                </div>
              </li>
              
              <li class="flex items-start space-x-4">
                <div class="flex-shrink-0 w-6 h-6 bg-orange-500 rounded-full flex items-center justify-center mt-0.5">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-slate-900 mb-1">No Man-Made Damage</h3>
                  <p class="text-sm text-slate-600 font-medium">Product must not be damaged by improper handling</p>
                </div>
              </li>
            </ul>
            
            <div class="mt-8 bg-gradient-to-r from-orange-600 to-orange-500 rounded-xl p-6 text-white shadow-lg shadow-orange-500/30">
              <div class="flex items-start space-x-3">
                <svg class="w-6 h-6 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <p class="text-sm font-medium leading-relaxed">
                  <strong class="font-bold block mb-1">Important:</strong>
                  Improper usage environment may shorten the lifespan of safety supplies. Please choose the appropriate protection level according to working conditions.
                </p>
              </div>
            </div>
          </div>
        </section>
      </div>

      <!-- How to Apply Section -->
      <section class="bg-gradient-to-r from-slate-900 to-slate-800 rounded-3xl shadow-xl overflow-hidden">
        <div class="p-10">
          <div class="flex items-center space-x-4 mb-8">
            <div class="w-16 h-16 bg-orange-500 rounded-2xl flex items-center justify-center shadow-lg shadow-orange-500/30">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div>
              <h2 class="text-2xl font-black text-white">How to Apply for Exchange?</h2>
              <p class="text-slate-300 font-medium text-sm">Follow these simple steps</p>
            </div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-white/5 backdrop-blur-sm rounded-xl p-6 border border-white/10">
              <div class="w-10 h-10 bg-orange-500 rounded-lg flex items-center justify-center text-white font-black mb-4">1</div>
              <h3 class="text-white font-bold mb-2">Document the Issue</h3>
              <p class="text-slate-300 text-sm font-medium leading-relaxed">Take clear photos or videos showing the product defect or issue</p>
            </div>
            
            <div class="bg-white/5 backdrop-blur-sm rounded-xl p-6 border border-white/10">
              <div class="w-10 h-10 bg-orange-500 rounded-lg flex items-center justify-center text-white font-black mb-4">2</div>
              <h3 class="text-white font-bold mb-2">Gather Information</h3>
              <p class="text-slate-300 text-sm font-medium leading-relaxed">Prepare your order number and purchase details</p>
            </div>
            
            <div class="bg-white/5 backdrop-blur-sm rounded-xl p-6 border border-white/10">
              <div class="w-10 h-10 bg-orange-500 rounded-lg flex items-center justify-center text-white font-black mb-4">3</div>
              <h3 class="text-white font-bold mb-2">Send Email</h3>
              <p class="text-slate-300 text-sm font-medium leading-relaxed">Email us with all documentation and wait for response</p>
            </div>
          </div>
          
          <div class="bg-white/5 backdrop-blur-sm rounded-xl p-8 border border-white/10">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
              <div>
                <p class="text-slate-300 font-medium mb-2 text-sm">Send detailed information to our support team:</p>
                <a href="mailto:oceantrade327@gmail.com" class="text-2xl font-black text-orange-400 hover:text-orange-300 transition-colors">oceantrade327@gmail.com</a>
              </div>
              <div class="flex-shrink-0">
                <%= link_to "Contact Support", contact_us_path, class: "inline-flex items-center px-8 py-4 bg-orange-600 text-white font-bold rounded-lg hover:bg-orange-700 transition-all shadow-lg shadow-orange-600/30" %>
              </div>
            </div>
          </div>
          
          <p class="mt-8 text-center text-slate-300 font-medium text-sm">
            Our team will complete the quality verification and assessment within 1-3 business days
          </p>
        </div>
      </section>
    </div>

    <!-- Back to Home -->
    <div class="mt-16 text-center">
      <%= link_to root_path, class: "inline-flex items-center space-x-2 text-slate-600 font-bold hover:text-orange-600 transition-all group" do %>
        <svg class="w-5 h-5 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        <span>Back to Home</span>
      <% end %>
    </div>
  </div>
</div>