<div class="bg-white min-h-screen pt-32 pb-32">
  <div class="container mx-auto px-6 lg:px-12 max-w-5xl">
    <div class="inline-block bg-slate-900 text-white text-[10px] font-black uppercase tracking-[0.3em] px-6 py-3 mb-10">
      Policy & Compliance
    </div>
    <h1 class="text-6xl md:text-8xl font-black text-slate-900 tracking-tighter leading-none uppercase mb-16 underline decoration-orange-500 decoration-8 underline-offset-8">
      Refund Policy
    </h1>

    <div class="space-y-24">
      <!-- Quality Promise -->
      <section>
        <h2 class="text-xs font-black uppercase tracking-[0.2em] mb-10 border-l-4 border-orange-600 pl-4 text-slate-900">Quality Promise</h2>
        <div class="p-12 border-4 border-slate-900 bg-slate-50 relative overflow-hidden group">
          <div class="absolute -top-10 -right-10 text-[10rem] font-black text-slate-100 select-none group-hover:text-orange-50/50 transition-colors">PROMISE</div>
          <p class="text-2xl font-black text-slate-900 relative z-10 leading-tight mb-8 uppercase">
            All safety product sales are considered final. In principle, no refunds will be given.
          </p>
          <p class="text-slate-500 font-bold relative z-10 leading-relaxed uppercase tracking-wide">
            US CHINA OCEAN INTERNATIONAL TRADE INC ensures every product meets industrial safety standards. Due to the special safety requirements of protective equipment, we only provide exchanges under specific quality issues.
          </p>
        </div>
      </section>

      <!-- Eligibility -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-20">
        <section>
          <h2 class="text-xs font-black uppercase tracking-[0.2em] mb-10 border-l-4 border-orange-600 pl-4 text-slate-900">Exchange Eligibility</h2>
          <div class="space-y-8 font-bold text-slate-900 uppercase tracking-tighter">
            <div class="flex items-start space-x-4 p-6 bg-slate-50 border border-slate-100 group hover:border-slate-900 transition-colors">
              <span class="text-orange-600 text-2xl">01</span>
              <span>Abnormal damage under normal usage conditions</span>
            </div>
            <div class="flex items-start space-x-4 p-6 bg-slate-50 border border-slate-100 group hover:border-slate-900 transition-colors">
              <span class="text-orange-600 text-2xl">02</span>
              <span>Failure to meet promised protection levels or safety standards</span>
            </div>
            <div class="flex items-start space-x-4 p-6 bg-slate-50 border border-slate-100 group hover:border-slate-900 transition-colors">
              <span class="text-orange-600 text-2xl">03</span>
              <span>Confirmed manufacturing defects</span>
            </div>
          </div>
        </section>

        <section>
          <h2 class="text-xs font-black uppercase tracking-[0.2em] mb-10 border-l-4 border-orange-600 pl-4 text-slate-900">Required Conditions</h2>
          <ul class="space-y-4 text-sm font-bold text-slate-500 uppercase tracking-widest">
            <li class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-orange-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
              <span>Provide proof of purchase (Order Number)</span>
            </li>
            <li class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-orange-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
              <span>Clear photo or video evidence</span>
            </li>
            <li class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-orange-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
              <span>No man-made damage or improper handling</span>
            </li>
          </ul>
          <div class="mt-12 p-6 bg-orange-600 text-white font-black text-xs uppercase tracking-[0.2em]">
            Improper usage environment may shorten the lifespan of safety supplies. Please choose the appropriate protection level according to working conditions.
          </div>
        </section>
      </div>

      <!-- Request -->
      <section class="p-12 border-4 border-slate-900">
        <h2 class="text-3xl font-black text-slate-900 uppercase tracking-tighter mb-8">How to Apply for Exchange?</h2>
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-8">
          <div class="space-y-4">
            <p class="text-slate-500 font-bold uppercase tracking-widest text-sm">Please send detailed information to our support email:</p>
            <p class="text-2xl font-black text-slate-900 underline decoration-orange-500">oceantrade327@gmail.com</p>
          </div>
          <div class="flex-shrink-0">
            <%= link_to "Contact Expert Now →", contact_us_path, class: "inline-block px-10 py-5 bg-slate-900 text-white font-black text-xs uppercase tracking-widest hover:bg-orange-600 transition-all" %>
          </div>
        </div>
        <p class="mt-10 text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">Our team will complete the quality verification and assessment within 1-3 business days.</p>
      </section>
    </div>

    <div class="mt-24 text-center">
      <%= link_to "← BACK TO HOME", root_path, class: "text-xs font-black uppercase tracking-widest text-slate-400 hover:text-slate-900 transition-colors" %>
    </div>
  </div>
</div>