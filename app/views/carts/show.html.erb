<div class="w-full max-w-6xl mx-auto">
  <div class="mb-8">
    <h1 class="text-4xl font-bold text-gray-900 mb-2">购物车</h1>
    <p class="text-gray-600">共 <%= @cart.total_quantity %> 件商品</p>
  </div>

  <% if @cart_items.any? %>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- 左侧：购物车商品列表 -->
      <div class="lg:col-span-2">
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div class="divide-y divide-gray-200">
            <% @cart_items.each do |cart_item| %>
              <div class="p-6 hover:bg-gray-50 transition">
                <div class="flex items-center space-x-4">
                  <!-- 商品图片 -->
                  <div class="flex-shrink-0">
                    <%= link_to product_path(cart_item.product) do %>
                      <% if cart_item.product.image.attached? %>
                        <%= image_tag cart_item.product.image, class: "h-24 w-24 object-cover rounded-lg" %>
                      <% else %>
                        <div class="h-24 w-24 bg-gray-200 rounded-lg flex items-center justify-center">
                          <span class="text-gray-400 text-xs">无图片</span>
                        </div>
                      <% end %>
                    <% end %>
                  </div>

                  <!-- 商品信息 -->
                  <div class="flex-1 min-w-0">
                    <%= link_to cart_item.product.name, product_path(cart_item.product), class: "text-lg font-semibold text-gray-900 hover:text-blue-600" %>
                    <p class="text-sm text-gray-500 mt-1">单价: ¥<%= number_to_currency(cart_item.product.price, unit: "", precision: 2) %></p>
                    
                    <!-- 数量控制 -->
                    <div class="mt-3 flex items-center space-x-3 cart-quantity-controls">
                      <span class="text-sm text-gray-600">数量:</span>
                      <div class="flex items-center border border-gray-300 rounded">
                        <%= button_to "-", decrease_quantity_cart_path(cart_item.id), method: :patch, class: "px-3 py-1 hover:bg-gray-100 text-gray-600", form: { data: { turbo_confirm: cart_item.quantity == 1 ? "数量为1时减少将删除该商品，确定吗？" : nil } } %>
                        <span class="px-4 py-1 border-x border-gray-300"><%= cart_item.quantity %></span>
                        <%= button_to "+", increase_quantity_cart_path(cart_item.id), method: :patch, class: "px-3 py-1 hover:bg-gray-100 text-gray-600" %>
                      </div>
                      <div class="cart-delete-button">
                        <%= button_to "删除", remove_item_cart_path(cart_item.id), method: :delete, class: "text-red-600 hover:text-red-800 text-sm", data: { turbo_confirm: "确定要删除这个商品吗？" } %>
                      </div>
                    </div>
                  </div>

                  <!-- 小计 -->
                  <div class="text-right">
                    <p class="text-xl font-bold text-gray-900">
                      ¥<%= number_to_currency(cart_item.subtotal, unit: "", precision: 2) %>
                    </p>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <!-- 继续购物按钮 -->
        <div class="mt-4">
          <%= link_to products_path, class: "inline-flex items-center text-blue-600 hover:text-blue-800" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            继续购物
          <% end %>
        </div>
      </div>

      <!-- 右侧：订单摘要 -->
      <div class="lg:col-span-1">
        <div class="bg-white rounded-lg shadow-lg p-6 sticky top-20">
          <h2 class="text-xl font-bold text-gray-900 mb-4">订单摘要</h2>
          
          <div class="space-y-3 mb-6">
            <div class="flex justify-between text-gray-600">
              <span>商品数量</span>
              <span><%= @cart.total_quantity %> 件</span>
            </div>
            <div class="flex justify-between text-gray-600">
              <span>商品总计</span>
              <span>¥<%= number_to_currency(@cart.total_price, unit: "", precision: 2) %></span>
            </div>
            <div class="flex justify-between text-gray-600">
              <span>运费</span>
              <span>免运费</span>
            </div>
          </div>

          <div class="border-t pt-4 mb-6">
            <div class="flex justify-between items-center">
              <span class="text-lg font-semibold text-gray-900">总计</span>
              <span class="text-2xl font-bold text-blue-600">
                ¥<%= number_to_currency(@cart.total_price, unit: "", precision: 2) %>
              </span>
            </div>
          </div>

          <%= link_to "#", class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 px-6 rounded-lg transition-colors text-center block" do %>
            去结账
          <% end %>

          <p class="text-xs text-gray-500 text-center mt-4">
            结账后将跳转到支付页面
          </p>
        </div>
      </div>
    </div>
  <% else %>
    <!-- 空购物车状态 -->
    <div class="bg-white shadow-lg rounded-lg p-16 text-center">
      <div class="text-gray-300 mb-6">
        <svg class="w-32 h-32 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
        </svg>
      </div>
      <h2 class="text-2xl font-semibold text-gray-700 mb-4">购物车是空的</h2>
      <p class="text-gray-500 mb-8">快去挑选喜欢的商品吧！</p>
      <%= link_to "去购物", products_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-lg transition-colors inline-block" %>
    </div>
  <% end %>
</div>
